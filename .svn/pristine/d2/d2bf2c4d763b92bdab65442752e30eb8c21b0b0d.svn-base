package com.elms.control;

import java.io.File;
import java.io.IOException;
import java.util.UUID;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpSession;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.multipart.MultipartFile;

import com.elms.service.AdminService;
import com.elms.vo.NoticeVO;
import com.elms.vo.UserVO;
import com.mysql.cj.Session;

@Controller
@RequestMapping("/admin")
public class AdminController {

	private static final String uploadPath = "D:\\WorkSpace\\eLMS05\\upload";
	
	@Autowired
	private AdminService adminService;

	@RequestMapping(value = "/notice/list.do")
	public String noticeList() {
		return "admin/notice/list";
	}

	@RequestMapping(value = "/notice/view.do")
	public String noticeView(String no, Model model) {

		if( no == null )
		{
			//게시물 번호가 지정 안됨.
			return "redirect:/admin/notice/list.do";
		}
		NoticeVO vo = adminService.Read(no);
		if(vo == null)
		{
			//게시물이 없음
			return "redirect:/admin/notice/list.do";			
		}

		model.addAttribute("notice",vo);
		return "admin/notice/view";
	}

	@RequestMapping(value = "/notice/write.do")
	public String noticeWrite() {

		return "admin/notice/write";
	}
	
	@RequestMapping(value = "/notice/writeok.do",method = RequestMethod.POST)
	public String noticeWriteok(NoticeVO vo,
			@RequestParam("attach")MultipartFile file)
					throws IllegalStateException, IOException
	{
		if( file != null )
		{
			//업로드된 원본 파일 이름 가져오기
			String originalFileName = file.getOriginalFilename();
			System.out.println("업로드한 원래 파일 이름:" + originalFileName);
			
			UUID uuid = UUID.randomUUID();
			String savedFileName = uuid.toString();
			System.out.println("물리적으로 저장한 파일 이름:" + savedFileName);
			
			String saveFileName = uploadPath + "\\" + savedFileName;
			
			File newFile = new File(saveFileName);
			
			file.transferTo(newFile);	
			
			vo.setFname(originalFileName); 
			vo.setPname(savedFileName);    			
		}
		adminService.Insert(vo);
		return "redirect:/admin/notice/view.do?no=" + vo.getNno();
		
	}
	
	 

	@RequestMapping(value = "/notice/update.do")
	public String noticeUpdate() {
		return "admin/notice/update";
	}

	@RequestMapping(value = "/teacher/list.do")
	public String teacherList() {
		return "admin/teacher/list";
	}

	@RequestMapping(value = "/student/list.do")
	public String studentList() {
		return "admin/student/list";
	}
}
