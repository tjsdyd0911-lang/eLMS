<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/admin/head.jsp" %>
  <div class="main-container">
        <aside>
            <div class="side-menu-top">
                <a href="../notice/list.jsp" class="menu-item active">공지사항</a>
                <a href="../teacher/list.jsp" class="menu-item">교사 관리</a>
                <a href="../student/list.jsp" class="menu-item">학생 관리</a>
            </div>
        </aside>
		<!-- 본문 내용 -->
		<main class="content-area">
			<!-- 헤더 영역 -->
			<div class="page-header">
				<h2 class="page-title">새 공지사항 작성</h2>
                <nav aria-label="breadcrumb">
                    <div class="breadcrumb">
                       <a href="list.jsp"> 공지사항 &nbsp; </a> > &nbsp;  <span>국가장학금 공지</span>
                    </div>
                </nav>
			</div>

			<!-- 작성 폼 -->
			<form action="#" method="post" enctype="multipart/form-data">

				<!-- 제목 -->
				<label class="form-label">제목</label> <input type="text"
					class="form-control-custom" placeholder="">

				<!-- 내용 -->
				<label class="form-label">내용</label>
				<textarea class="form-control-custom"></textarea>

				<!-- 첨부파일 -->
				<label class="form-label">첨부파일</label>
				<div class="file-upload-box">
					<i class="fa-solid fa-paperclip file-icon"></i>
					<div>
						<input type="file" id="fileInput" name="file">
					</div>
				</div>

				<!-- 버튼 영역 -->
				<div class="btn-area">
					<a href="view.jsp"><button type="button" class="btn-custom btn-blue">등록</button></a>
					<button type="button" class="btn-custom btn-grey"
						onclick="history.back()">취소</button>
				</div>

			</form>
		</main>

	</div>

	<!-- 부트스트랩 JS (필요시) -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>