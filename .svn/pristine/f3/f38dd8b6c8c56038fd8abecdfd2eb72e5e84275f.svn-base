	//과제 삭제 처리
	@RequestMapping(value = "/task/task_del.do/{tno}/{edate}", method = RequestMethod.DELETE, produces = "text/plain; charset=UTF-8")
	@ResponseBody
	public ResponseEntity<String> TaskDel(@PathVariable int tno, @PathVariable String edate, HttpSession session) {
		//오늘 날짜 YYMMDD 형식의 문자열로 변환
		int today = Integer.parseInt(LocalDate.now().format(DateTimeFormatter.ofPattern("yyyyMMdd")));
		int intEdate = Integer.parseInt(edate.replace("-", ""));
		
		if(today > intEdate) {
			return new ResponseEntity<String>("제출 마감일이 지났습니다.", HttpStatus.PRECONDITION_FAILED);
		}
		
		UserVO loginUser = (UserVO) session.getAttribute("login");
		int uno = loginUser.getUno();
		
		try {
			teacherService.TaskDel(tno, uno);
			return new ResponseEntity<String>("삭제되었습니다.", HttpStatus.OK);
		}catch (DataIntegrityViolationException e) {
            // 외래키 제약조건 위반 시 409 Conflict 반환
            return new ResponseEntity<String>("해당 과제를 제출한 학생이 있습니다.", HttpStatus.CONFLICT);
        } catch (Exception e) {
            // 그 외 알 수 없는 에러는 500 에러 반환
            return new ResponseEntity<String>("삭제실패 : 재시도 또는 관리자에게 문의하세요.", HttpStatus.INTERNAL_SERVER_ERROR);
        }
	}
		
	//과제 수정 화면
	@RequestMapping(value = "/task/update.do")
	public String TaskUpdate(int tno, int sno, String sname, String edate, Model model) {
		//오늘 날짜 YYMMDD 형식의 문자열로 변환
		int today = Integer.parseInt(LocalDate.now().format(DateTimeFormatter.ofPattern("yyyyMMdd")));
		int intEdate = Integer.parseInt(edate.replace("-", ""));
		
		if(today > intEdate) {
			return "redirect:/teacher/task/list.do?sno="+ sno;
		}
		
		if (tno <= 0) return "redirect:/teacher/task/list.do?sno="+ sno;
		TaskVO vo = teacherService.taskView(tno);
		
		model.addAttribute("view", vo);
		model.addAttribute("sname", sname);
		return "teacher/task/update";
	}
	
	//과제 수정 처리
	@RequestMapping(value = "/task/updateok.do")
	public String TaskUpdateok(TaskVO vo, @RequestParam("attach")MultipartFile file) throws IllegalStateException, IOException {
		//System.out.println("sname=" + vo.getSname());
		//첨부파일 있으면 upload 폴더에 저장한다.
		if( file != null )
		{
			//업로드된 원본 파일 이름 가져오기
			String originalFileName = file.getOriginalFilename();
			System.out.println("업로드한 원래 파일 이름:" + originalFileName);
			
			//파일 이름이 중복되지 않도록 파일이름을 변경해서 저장
			//물리 파일이름(savedFileName), 논리파일 이름(originalFileName)
			UUID uuid = UUID.randomUUID();
			String savedFileName = uuid.toString();
			System.out.println("물리적으로 저장한 파일 이름:" + savedFileName);
			
			//첨부파일을 upload 폴더에 저장한다.
			String saveFileName = uploadPath + "\\" + savedFileName;
			//saveFileName<-- upload\a.jpg
			
			//첨부파일을 저장하기 위한 객체 생성
			File newFile = new File(saveFileName);
			
			//실제로 저장한다.
			file.transferTo(newFile);	
			
			vo.setFname(originalFileName); //원본파일명
			vo.setPname(savedFileName);    //저장된 파일명			
		}
		teacherService.TaskUpdate(vo);
		
		return "redirect:/teacher/task/view.do?tno=" + vo.getTno() + "&sname=" + URLEncoder.encode(vo.getSname(),"utf-8");
	}
	
	//과제 채점모달 정보 불러오기
	@RequestMapping(value = "/task/load_task.do", method = RequestMethod.POST, produces = "text/plain; charset=UTF-8")
	@ResponseBody
	public String LoadTask(SubmissionVO vo) {
		SubmissionVO load = teacherService.LoadTask(vo);

		//Json 변환처리
		return ConvertUtil.toJson(load);
	}
	
	//과제 채점 저장하기
	@RequestMapping(value = "/task/score.do", method = RequestMethod.POST, produces = "text/plain; charset=UTF-8")
	@ResponseBody
	public String ScoreUpdate(SubmissionVO vo, @RequestParam("attach")MultipartFile file) throws IllegalStateException, IOException {
		
		String score = vo.getScore();
		//점수가 정수 또는 소수점 둘째자리까지 검사
		String grade = "^(100(\\.0{1,2})?|[0-9]{1,2}(\\.[0-9]{1,2})?)$";
		
		//첨부파일 있으면 upload 폴더에 저장한다.
		if( file != null )
		{
			//업로드된 원본 파일 이름 가져오기
			String originalFileName = file.getOriginalFilename();
			
			//파일 이름이 중복되지 않도록 파일이름을 변경해서 저장
			//물리 파일이름(savedFileName), 논리파일 이름(originalFileName)
			UUID uuid = UUID.randomUUID();
			String savedFileName = uuid.toString();
			
			//첨부파일을 upload 폴더에 저장한다.
			String saveFileName = uploadPath + "\\" + savedFileName;
			//saveFileName<-- upload\a.jpg
			
			//첨부파일을 저장하기 위한 객체 생성
			File newFile = new File(saveFileName);
			
			//실제로 저장한다.
			file.transferTo(newFile);	
			
			vo.setFfname(originalFileName); //원본파일명
			vo.setFpname(savedFileName);    //저장된 파일명			
		}
		
		if(vo.getStype() == "01" && score != null && score.matches(grade)) {
			teacherService.ScoreUpdate(vo);
		} else if(vo.getStype() == "02" && score != null && ("P".equals(score) || "F".equals(score)) ) {
			teacherService.ScoreUpdate(vo);
		}
		
		return "OK";
	}
}
