<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../include/user/head.jsp" %>
<form id="findFrm" name="findFrm" method="post" action="pw_findok.do">
<input type="hidden" id="find_uid" name="uid">
<input type="hidden" id="find_num" name="num">
<input type="hidden" id="find_name" name="name">
<input type="hidden" id="find_hp" name="hp">
</form>
<script>
	function PwFind(){
		if( $("#uid").val() == "" ){
			$("#uid").focus()
			alert("이메일(ID)를 입력하세요.")
			return;
		}
		
		if( $("#num").val() == "" ){
			if( $("#idLabel").html().trim() == "학번"){
				$("#num").focus()
				alert("학번을 입력하세요.")
				return;	
			}else{
				$("#num").focus()
				alert("사번을 입력하세요.")
				return;
			}
		}
		
		if( $("#name").val() == "" ){
			$("#name").focus()
			alert("이름을 입력하세요.")
			return;
		}
		
		if( $("#hp").val() == "" ){
			$("#hp").focus()
			alert("핸드폰 번호를 입력하세요.")
			return;
		}

		$.ajax({
			url: "pw_find_check.do",
			type: "post",
			dataType: "html",
			data :
			{
				uid   : $("#uid").val(),
				num   : $("#num").val(),
				name  : $("#name").val(),
				hp    : $("#hp").val()
			},
			success : function(data)
			{
				data = data.trim();
				if( data == "FIND" )
				{
					$("#find_uid").val($("#uid").val());
					$("#find_num").val($("#num").val());
					$("#find_name").val($("#name").val());
					$("#find_hp").val($("#hp").val());
					$("#findFrm").submit();
				}else
				{
					alert("입력하신 정보가 일치하지 않습니다.");
					$("#uid").focus();
				}
			},
			error : function(xhr,status,error)
			{
				alert("실패");
			}
		});
	}
</script>
        <main>
            <div class="pw-find-card">
                <h2>비밀번호찾기</h2>
                
                <!-- 학생/교수 선택 캡슐 -->
                <div class="toggle-capsule">
                    <div id="btnStudent" class="type-item" onclick="switchUserType('student')">
                        <span class="dot-radio"></span> 학생
                    </div>
                    <div id="btnProfessor" class="type-item active" onclick="switchUserType('professor')">
                        <span class="dot-radio"></span> 교수
                    </div>
                </div>

                <!-- 폼 시작 -->
                <form>
                    <div class="text-start">
                        <label class="form-label">이메일 주소(ID)</label>
                        <input type="email" id="uid" name="uid" class="form-control custom-input" placeholder="example@ezen.ac.kr">
                    </div>
                    
                    <div class="text-start">
                        <label class="form-label" id="idLabel">사번</label>
                        <input type="text" id="num" name="num" class="form-control custom-input" placeholder="사번 8자리를 입력하세요">
                    </div>

                    <div class="text-start">
                        <label class="form-label">이름</label>
                        <input type="text" id="name" name="name" class="form-control custom-input" placeholder="실명을 입력하세요">
                    </div>

                    <div class="text-start">
                        <label class="form-label">핸드폰 번호</label>
                        <input type="text" id="hp" name="hp" class="form-control custom-input" placeholder="010-0000-0000">
                    </div>
                    
                    <button type="button" class="btn btn-reset" onclick="PwFind();">비밀번호 재설정</button>
                </form>

                <a href="login.do" class="footer-link">로그인하러 가기</a>
            </div>
        </main>
    </div>

    <!-- 부트스트랩 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 학생 vs 교수 전환 함수
        function switchUserType(type) {
        	if (type === 'student') {
                // 학생 선택 시
            	$("#idLabel").text('학번');
            	$("#num").attr('placeholder', '학번 8자리를 입력하세요');
            	$("#btnStudent").addClass('active');
            	$("#btnProfessor").removeClass('active');
           	 	$("#btnStudent").find('.dot-icon').css('background', '#333');
                $("#btnProfessor").find('.dot-icon').css('background', 'transparent');
                $("#btnProfessor").find('.dot-icon').css('border', '1px solid #ccc');
            } else {
                // 교수 선택 시
            	$("#idLabel").text('사번');
                $("#num").attr('placeholder', '사번 8자리를 입력하세요');
                $("#btnProfessor").addClass('active');
                $("#btnStudent").removeClass('active');
                $("#btnProfessor").find('.dot-icon').css('background', '#333');
                $("#btnStudent").find('.dot-icon').css('background', 'transparent');
                $("#btnStudent").find('.dot-icon').css('border', '1px solid #ccc');
            }
        }
    </script>
</body>
</html>