<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/teacher/head.jsp" %>
    <div class="main-container">
      <aside>
        <div class="side-menu-top">
         	<a href="../notice/list.do" class="menu-item">공지사항</a>
            <a href="../subject/list.do" class="menu-item active">과목 관리</a>
            <a href="../task/list.do" class="menu-item">과제 게시판</a>
        </div>
<%@ include file="../../include/teacher/side.jsp" %>           
      </aside>

		<main>
			<!-- 페이지 타이틀 & 등록 버튼 -->
			<div
				class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-2 border-dark">
				<h2 class="m-0 fw-bold text-dark">담당 과목 관리</h2>
				<!-- 모달 트리거 버튼 -->
				<button class="btn btn-primary" data-bs-toggle="modal"
					data-bs-target="#registerModal">
					<i class="fa-solid fa-plus me-1"></i> 과목 등록
				</button>
			</div>

			<!-- 테이블 (Bootstrap) -->
			<div class="table-responsive">
				<table class="table table-hover text-center">
					<colgroup>
						<col style="width: 5%;">
						<col style="width: 18%;">
						<col style="width: 15%;">
						<col style="width: 17%;">
						<col style="width: 15%;">
						<col style="width: 10%;">
						<col style="width: 10%;">
						<col style="width: 10%;">
					</colgroup>
					<thead>
						<tr>
							<th>번호</th>
							<th>과목명</th>
							<th>수강신청 기간</th>
							<th>강의 기간</th>
							<th>강의 상태</th>
							<th>신청 현황</th>
							<th>과제 관리</th>
							<th>관리</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>1</td>
							<td class="text-start ps-4">웹디자인실습</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td><span class="badge-pill rounded-pill text-bg-success">강의중</span></td>
							<td>30/50</td>
							<td><a href="../task/list.do"><button class="btn btn-sm btn-warning text-white">과제 관리</button></a></td>
							<td>
								<button class="btn btn-sm btn-primary" data-bs-toggle="modal"
									data-bs-target="#editModal">수정</button>
								<button class="btn btn-sm btn-danger">삭제</button>
							</td>
						</tr>
						<tr>
							<td>2</td>
							<td class="text-start ps-4">사용자 경험(UX) 분석</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td><span class="badge-pill rounded-pill text-bg-secondary">개설준비중</span></td>
							<td>0/30</td>
							<td><a href="../task/list.do"><button
										class="btn btn-sm btn-warning text-white">과제 관리</button></a></td>
							<td>
								<button class="btn btn-sm btn-primary" data-bs-toggle="modal"
									data-bs-target="#editModal">수정</button>
								<button class="btn btn-sm btn-danger">삭제</button>
							</td>
						</tr>
						<tr>
							<td>3</td>
							<td class="text-start ps-4">프론트엔드 프레임워크 기초</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td>2024.03.02 ~ 2024.06.20</td>
							<td><span class="badge-pill rounded-pill" style="background-color: #d63384;">강의 완료</span></td>
							<td>20/50</td>
							<td><a href="../task/list.do"><button class="btn btn-sm btn-warning text-white">과제 관리</button></a></td>
							<td>
								<button class="btn btn-sm btn-primary" data-bs-toggle="modal"
									data-bs-target="#editModal">수정</button>
								<button class="btn btn-sm btn-danger">삭제</button>
							</td>
						</tr>
					</tbody>
				</table>
			</div>

			<!-- 페이지네이션 (Bootstrap) -->
            <div class="pagination gap-2">
            	<a href="#" class="page-num">◀</a>
                <a href="#" class="page-num choice">1</a>
                <a href="#" class="page-num">2</a>
                <a href="#" class="page-num">3</a>
                <a href="#" class="page-num">4</a>
                <a href="#" class="page-num">5</a>
                <a href="#" class="page-num">▶</a>
            </div>
		</main>
	</div>

	<!-- ========================================== -->
	<!-- [MODAL 1] 새 과목 등록 모달 -->
	<!-- ========================================== -->
	<div class="modal fade" id="registerModal" tabindex="-1"
		aria-labelledby="registerModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg modal-dialog-centered">
			<div class="modal-content p-3">
				<div class="modal-header border-0 pb-0">
					<h4 class="modal-title" id="registerModalLabel">새 과목 등록</h4>
					<button type="button" class="btn-close" data-bs-dismiss="modal"
						aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<form>
						<div class="mb-4">
							<label for="regSubjectName" class="form-label">과목명</label> <input
								type="text" class="form-control" id="regSubjectName"
								placeholder="예: 파이썬 중급 프로그래밍">
						</div>
						<div class="mb-4">
							<label class="form-label">강의 기간</label>
							<div class="row g-2">
								<div class="col">
									<input type="date" class="form-control">
								</div>
								<div class="col-auto date-separator">~</div>
								<div class="col">
									<input type="date" class="form-control">
								</div>
							</div>
						</div>
						<div class="mb-4">
							<label class="form-label">수강신청 기간</label>
							<div class="row g-2">
								<div class="col">
									<input type="date" class="form-control">
								</div>
								<div class="col-auto date-separator">~</div>
								<div class="col">
									<input type="date" class="form-control">
								</div>
							</div>
						</div>
						<div class="mb-4 row align-items-center">
							<label class="col-sm-3 col-form-label fw-bold">수강가능인원</label>
							<div class="col-sm-9">
								<div class="input-group" style="max-width: 200px;">
									<input type="number" class="form-control text-end" min="0">
									<span class="input-group-text">명</span>
								</div>
							</div>
						</div>
					</form>
				</div>
				<div class="modal-footer border-0 pt-0">
					<button type="button" class="btn btn-secondary px-4"
						data-bs-dismiss="modal">취소</button>
					<button type="button" class="btn btn-primary px-4">등록하기</button>
				</div>
			</div>
		</div>
	</div>

	<!-- ========================================== -->
	<!-- [MODAL 2] 과목 수정 모달 -->
	<!-- ========================================== -->
	<div class="modal fade" id="editModal" tabindex="-1"
		aria-labelledby="editModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg modal-dialog-centered">
			<div class="modal-content p-3">
				<div class="modal-header border-0 pb-0">
					<h4 class="modal-title" id="editModalLabel">과목 수정</h4>
					<button type="button" class="btn-close" data-bs-dismiss="modal"
						aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<form>
						<div class="mb-4">
							<label for="editSubjectName" class="form-label">과목명</label> <input
								type="text" class="form-control" id="editSubjectName"
								value="파이썬 중급 프로그래밍">
						</div>
						<div class="mb-4">
							<label class="form-label">강의 기간</label>
							<div class="row g-2">
								<div class="col">
									<input type="date" class="form-control" value="2024-03-02">
								</div>
								<div class="col-auto date-separator">~</div>
								<div class="col">
									<input type="date" class="form-control" value="2024-05-31">
								</div>
							</div>
						</div>
						<div class="mb-4">
							<label class="form-label">수강신청 기간</label>
							<div class="row g-2">
								<div class="col">
									<input type="date" class="form-control">
								</div>
								<div class="col-auto date-separator">~</div>
								<div class="col">
									<input type="date" class="form-control">
								</div>
							</div>
						</div>
						<div class="mb-4 row align-items-center">
						  <!-- 1. 수강가능인원 라벨 (3칸) -->
						  <label class="col-sm-2 col-form-label fw-bold">수강가능인원</label>
						  
						  <!-- 2. 수강가능인원 입력칸 (4칸) -->
						  <div class="col-sm-4">
						    <div class="input-group">
						      <input type="number" class="form-control text-end" value="30">
						      <span class="input-group-text">명</span>
						    </div>
						  </div>
						
						  <!-- 3. 현재신청인원 라벨 (3칸) -->
						  <label class="col-sm-2 col-form-label fw-bold text-sm-end">현재신청인원</label>
						  
						  <!-- 4. 현재신청인원 표시칸 (3칸) -->
						  <div class="col-sm-4">
						    <div class="input-group">
						      <span class="input-group-text text-end">23명</span>
						    </div>
						  </div>
						</div>
					</form>
				</div>
				<div class="modal-footer border-0 pt-0">
					<button type="button" class="btn btn-secondary px-4"
						data-bs-dismiss="modal">취소</button>
					<button type="button" class="btn btn-primary px-4">수정하기</button>
				</div>
			</div>
		</div>
	</div>

	<!-- [Bootstrap 5 JS Bundle] -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>