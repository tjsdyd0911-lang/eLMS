<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ include file="../include/user/head.jsp" %>
<script src="resources/js/join.js"></script>
        <main>
            <div class="login-card">
                <h2>로그인</h2>
	                <div class="mb-3 text-start">
	                    <label class="form-label">이메일 주소(ID)</label>
	                    <input type="email" id="lid" name="uid" class="form-control custom-input" placeholder="example@ezen.ac.kr">
	                </div>                
	                <div class="mb-4 text-start">
	                    <label class="form-label">비밀번호</label>
	                    <input type="password" id="lpw" name="pw" class="form-control custom-input" placeholder="*********">
	                </div>
	                	<button id="btnLogin" class="btn btn-login">로그인</button>
                <div class="auth-footer mt-4 text-muted" style="font-size:13px;">
                    <!-- 회원가입 버튼 -->
                    <a href="#" class="text-decoration-none text-muted" data-bs-toggle="modal" data-bs-target="#signUpModal">회원가입</a> 
                    <span class="mx-2">|</span>
                    <a href="id_find.do" class="text-decoration-none text-muted">아이디 찾기</a>
                    <span class="mx-2">|</span>
                    <a href="pw_find.do" class="text-decoration-none text-muted">비밀번호 재설정</a>
                </div>
                <a href="javascript:setinfo('admin@univ.ac.kr', 'admin123');">관리자</a> 
                <a href="javascript:setinfo('prof01@univ.ac.kr', 'teacher123');">교수</a>
                <a href="javascript:setinfo('std01@univ.ac.kr', 'student123');">학생</a>
            </div>
        </main>
    </div>

    <!-- 회원가입 모달: data-bs-backdrop="static" 속성으로 외부 클릭 시 닫힘 방지 -->
    <div class="modal fade" id="signUpModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="signUpModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- 헤더 영역 -->
                <div class="modal-header d-block text-center">
                    <h3 class="fw-bold mb-0" style="color:#2D3E50;">회원가입</h3>
                    <!-- Font Awesome 닫기 아이콘 버튼 -->
                    <button type="button" class="modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="modal-body px-4">
                    <!-- 학생/교수 선택 토글 -->
                    <div class="d-flex justify-content-center mb-4">
                        <div id="btnStudent" class="user-toggle-btn active" onclick="switchUserType('student')">
                            <span class="dot-icon" style="background:#333;"></span> 학생
                        </div>
                        <div id="btnProfessor" class="user-toggle-btn" onclick="switchUserType('professor')">
                            <span class="dot-icon" style="border:1px solid #ccc;"></span> 교수
                        </div>
                    </div>

                    <!-- 폼 영역 -->
                    <form id="signUpForm">
                        <div class="mb-3">
                            <label class="form-label">이메일 주소(ID)</label>
                            <input type="email" id="jid" name="uid" maxlength="50" class="form-control custom-input" placeholder="example@ezen.ac.kr"  onkeyup="SetBlank(this);" required>
                            <span id="imsg"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">이름</label>
                            <input type="text" id="name" name="name" class="form-control custom-input" placeholder="실명을 입력하세요"  onkeyup="SetBlank(this);">
                        </div>                       
                        <div class="mb-3" id="deptArea">
                            <label class="form-label">학과</label>
                            <select id="major" name="major" class="form-select custom-input">
                                <option value="01" selected>컴퓨터공학과</option>
                                <option value="02">경영학과</option>
                                <option value="03">국어국문학과</option>
                                <option value="04">기계공학과</option>
                                <option value="05">사회학과</option>
                                <option value="06">시각디자인학과</option>
                                <option value="07">심리학과</option>
                                <option value="08">생명공학과</option>
                                <option value="09">전자공학과</option>
                                <option value="10">정치외교학과</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" id="idLabel">학번</label>
                            <input type="text" id="num" name="num" maxlength="8" class="form-control custom-input" placeholder="학번 8자리를 입력하세요" onkeyup="SetBlank(this);">
                            <span id="nmsg"></span>
                        </div>
						<div class="mb-3">
						    <label class="form-label">비밀번호</label>
						    <!-- 아이콘 배치를 위해 input을 감싸는 div 추가 -->
						    <div class="position-relative">
						        <input type="password" minlength="8" maxlength="16" class="form-control custom-input pe-5" 
						               id="jpw" name="pw" placeholder="8자 이상 16자 이하의 비밀번호" onkeyup="SetPw();">
						        <i id="togglePw" class="fa fa-eye position-absolute top-50 end-0 translate-middle-y me-3" 
						           style="cursor: pointer; z-index: 10;"></i>
						    </div>
						    <span id="pmsg"></span>
						</div>
                        <div class="mb-3">
                            <label class="form-label">비밀번호 확인</label>
                            <input type="password" id="pwcheck" name="pwcheck" minlength="8" maxlength="16" class="form-control custom-input" placeholder="비밀번호 재입력" onkeyup="SetPw();">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">핸드폰 번호</label>
                            <input type="tel" id="hp" name="hp" maxlength="13" oninput="autoHyphen(this)" class="form-control custom-input" placeholder="010-0000-0000">
                        </div>
                    </form>
                </div>

                <div class="modal-footer d-grid gap-2 w-100 px-4">
                   <button type="button" id="btnJoin" name="btnJoin" class="btn btn-primary btn-lg border-0" style="background-color:#3498db; font-weight: bold;">가입하기</button>
                   <a href="login.do" class="text-center text-decoration-none mt-2" data-bs-dismiss="modal" style="color:#3498db; font-size:14px; font-weight:bold;">로그인하러 가기</a>
                </div>
            </div>
        </div>
    </div>

    <!-- 부트스트랩 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 학생 vs 교수 전환 스크립트
        function switchUserType(type) {
        	$("input").val(""); 
        	
            if (type == "student") {
            	uType = "S";
            	$("#deptArea").removeClass('d-none');
            	$("#idLabel").text('학번');
            	$("#imsg").html("");
            	$("#nmsg").html("");
            	$("#num").attr('placeholder', '학번 8자리를 입력하세요');
            	$("#btnStudent").addClass('active');
            	$("#btnProfessor").removeClass('active');
                $("#btnStudent").find('.dot-icon').css('background', '#333');
                $("#btnProfessor").find('.dot-icon').css('background', 'transparent');
                $("#btnProfessor").find('.dot-icon').css('border', '1px solid #ccc');
                       	    
            } else {
            	uType = "T";
            	$("#deptArea").addClass('d-none');
                $("#idLabel").text('사번');
            	$("#imsg").html("");                
            	$("#nmsg").html("");                
                $("#num").attr('placeholder', '사번 8자리를 입력하세요');
                $("#btnProfessor").addClass('active');
                $("#btnStudent").removeClass('active');
                $("#btnProfessor").find('.dot-icon').css('background', '#333');
                $("#btnStudent").find('.dot-icon').css('background', 'transparent');
                $("#btnStudent").find('.dot-icon').css('border', '1px solid #ccc');
                
            }
        }
    </script>
</body>
</html>