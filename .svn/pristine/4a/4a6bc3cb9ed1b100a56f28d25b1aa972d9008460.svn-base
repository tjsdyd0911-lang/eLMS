<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ include file="../include/user/head.jsp" %>
<script>
window.onload = function()
{
	$("#uid").focus();
	
	$("#btnJoin").click(function(){
		DoJoin();
	});
	
	$("#btnLogin").click(function(){
		DoLogin();
	});	
	
	$("#jid").keyup(function(){
		CheckId();
	});
	
	$("#num").keyup(function(){
		CheckNum();
	});
}

function setinfo(id, pw){
	$("#lid").val(id);
	$("#lpw").val(pw);
}

var uType = "S";  //구분(S-학생, T-교사, A-관리자)
function DoJoin()
{
	if( IsDuplicate == true )
	{
		$("#jid").focus();
		alert("중복된 이메일(ID)입니다.");
		return;
	}
	
	if( $("#jid").val() == "" )
	{
		$("#jid").focus();
		alert("이메일을 입력하세요.");
		return;
	}
	if( $("#name").val() == "" )
	{
		$("#name").focus();
		alert("이름을 입력하세요.");
		return;
	}
	if( $("#major").val() == "" )
	{
		$("#major").focus();
		alert("학과를 선택하세요.");
		return;
	}
	if( $("#num").val() == "" )
	{
		$("#num").focus();
		alert("학번을 입력하세요.");
		return;
	}
	if( $("#jpw").val() == "" )
	{
		$("#jpw").focus();
		alert("비밀번호를 입력하세요.");
		return;
	}
	if( $("#jpw").val() != $("#pwcheck").val() )
	{
		$("#jpw").focus();
		alert("비밀번호가 일치하지 않습니다.");
		return;
	}
	if( $("#hp").val() == "")
	{
		$("#hp").focus();
		alert("핸드폰 번호를 입력하세요.");
		return;
	}
	
	$.ajax({
		url: "joinok.do",
		type: "post",
		dataType: "html",
		data :
		{
			utype : uType,
			uid   : $("#jid").val(),
			name  : $("#name").val(),
			major : $("#major").val(),
			num   : $("#num").val(),
			pw    : $("#jpw").val(),
			hp    : $("#hp").val()
		},
		success : function(data)
		{
			data = data.trim();
			if( data == "OK" )
			{
				document.location = "login.do";
			}else
			{
				alert("아이디 또는 비밀번호가 일치하지 않습니다.");
				$("#jid").focus();
			}
		},
		error : function(xhr,status,error)
		{
			alert("실패");
		}
	});

}


var IsDuplId= false; //true: 중복, false: 중복안됨
function CheckId(){
	IsDuplId = false;
	
	jid=$("#jid").val();
	if(jid == ""){
		$("#imsg").html("이메일(ID)를 입력하세요.");
		return;
	}
	
	$.ajax({
		url: "checkid.do?uid=" + jid,
		type: "get",
		dataType: "html",
		success : function(data)
		{
			//통신이 성공적으로 이루어지면  success 가 동작함.
			data = data.trim();
			if(data == "Y"){
				$("#imsg").html("아이디가 중복되었습니다.");	
				IsDuplId = true;
			}else{
				$("#imsg").html("등록 가능한 아이디입니다.");
			}
			
			
		},
		error : function(xhr,status,error)
		{
			//통신 오류 발생시 error가 동작함.
			alert("실패");
		}
	});
}

var IsDuplNum= false; //true: 중복, false: 중복안됨
function CheckNum(){
	IsDuplNum = false;
	
	num=$("#num").val();
	if( uType == "S" ){
		if( num == ""){
			$("#nmsg").html("학번을 입력하세요.");
			return;
		}
	}else if( uType == "T"){
		if( num == ""){
			$("#nmsg").html("사번을 입력하세요.");
			return;
		}
	}
	
	$.ajax({
		url: "checknum.do?num=" + num,
		type: "get",
		dataType: "html",
		success : function(data)
		{
			//통신이 성공적으로 이루어지면  success 가 동작함.
			data = data.trim();
			if(uType == "S" && data == "impossible"){
				$("#nmsg").html("학번이 중복되었습니다.");	
				IsDuplNum = true;
			}else if(uType == "T" && data == "impossible"){
				$("#nmsg").html("사번이 중복되었습니다.");	
			}else{
				$("#nmsg").html("등록 가능한 아이디입니다.");
			}
			
			
		},
		error : function(xhr,status,error)
		{
			//통신 오류 발생시 error가 동작함.
			alert("실패");
		}
	});
}


function DoLogin()
{
	if( $("#lid").val() == "" )
	{
		$("#lid").focus();
		alert("이메일을 입력하세요.");
		return;
	}
	if( $("#lpw").val() == "" )
	{
		$("#lpw").focus();
		alert("비밀번호를 입력하세요.");
		return;
	}

	$.ajax({
		url: "loginok.do",
		type: "post",
		dataType: "html",
		data :
		{
			uid : $("#lid").val(),
			pw : $("#lpw").val()
		},
		success : function(data)
		{
			data = data.trim();
			if( data == "S" )
			{
				document.location = "student/apply/apply.do";
			}else if( data =="T")
			{
				document.location = "teacher/subject/list.do";
				
			}else if( data =="A")
			{
				document.location = "admin/notice/list.do";
				
			}else
			{
				alert("아이디 또는 비밀번호가 일치하지 않습니다.");
				$("#lid").focus();
			}
		},
		error : function(xhr,status,error)
		{
			alert("실패");
		}
	});
	
}

</script>

        <main>
            <div class="login-card">
                <h2>로그인</h2>
	                <div class="mb-3 text-start">
	                    <label class="form-label">이메일 주소(ID)</label>
	                    <input type="email" id="lid" name="uid" class="form-control custom-input" placeholder="example@ezen.ac.kr">
	                </div>                
	                <div class="mb-4 text-start">
	                    <label class="form-label">비밀번호</label>
	                    <input type="password" id="lpw" name="pw" class="form-control custom-input" placeholder="*********">
	                </div>
	                	<button id="btnLogin" class="btn btn-login">로그인</button>
                <div class="auth-footer mt-4 text-muted" style="font-size:13px;">
                    <!-- 회원가입 버튼 -->
                    <a href="#" class="text-decoration-none text-muted" data-bs-toggle="modal" data-bs-target="#signUpModal">회원가입</a> 
                    <span class="mx-2">|</span>
                    <a href="id_find.do" class="text-decoration-none text-muted">아이디 찾기</a>
                    <span class="mx-2">|</span>
                    <a href="pw_find.do" class="text-decoration-none text-muted">비밀번호 재설정</a>
                </div>
                <a href="javascript:setinfo('admin@univ.ac.kr', 'admin123');">관리자</a> 
                <a href="javascript:setinfo('prof01@univ.ac.kr', '1234');">교수</a>
                <a href="javascript:setinfo('std01@univ.ac.kr', '1234');">학생</a>
            </div>
        </main>
    </div>

    <!-- 회원가입 모달: data-bs-backdrop="static" 속성으로 외부 클릭 시 닫힘 방지 -->
    <div class="modal fade" id="signUpModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="signUpModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- 헤더 영역 -->
                <div class="modal-header d-block text-center">
                    <h3 class="fw-bold mb-0" style="color:#2D3E50;">회원가입</h3>
                    <!-- Font Awesome 닫기 아이콘 버튼 -->
                    <button type="button" class="modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="modal-body px-4">
                    <!-- 학생/교수 선택 토글 -->
                    <div class="d-flex justify-content-center mb-4">
                        <div id="btnStudent" class="user-toggle-btn active" onclick="switchUserType('student')">
                            <span class="dot-icon" style="background:#333;"></span> 학생
                        </div>
                        <div id="btnProfessor" class="user-toggle-btn" onclick="switchUserType('professor')">
                            <span class="dot-icon" style="border:1px solid #ccc;"></span> 교수
                        </div>
                    </div>

                    <!-- 폼 영역 -->
                    <form id="signUpForm">
                        <div class="mb-3">
                            <label class="form-label">이메일 주소(ID)</label>
                            <input type="email" id="jid" name="uid" class="form-control custom-input" value="example@ezen.ac.kr">
                            <span id="imsg"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">이름</label>
                            <input type="text" id="name" name="name" class="form-control custom-input" placeholder="실명을 입력하세요">
                        </div>                       
                        <div class="mb-3" id="deptArea">
                            <label class="form-label">학과</label>
                            <select id="major" name="major" class="form-select custom-input">
                                <option value="01" selected>컴퓨터공학과</option>
                                <option value="02">경영학과</option>
                                <option value="03">국어국문학과</option>
                                <option value="04">기계공학과</option>
                                <option value="05">사회학과</option>
                                <option value="06">시각디자인학과</option>
                                <option value="07">심리학과</option>
                                <option value="08">생명공학과</option>
                                <option value="09">전자공학과</option>
                                <option value="10">정치외교학과</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" id="idLabel">학번</label>
                            <input type="text" class="form-control custom-input" id="num" name="num" placeholder="학번 8자리를 입력하세요">
                            <span id="nmsg"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">비밀번호</label>
                            <input type="password" class="form-control custom-input" id="jpw" name="pw" placeholder="8자 이상의 비밀번호">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">비밀번호 확인</label>
                            <input type="password" class="form-control custom-input" id="pwcheck" name="pwcheck" placeholder="비밀번호 재입력">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">핸드폰 번호</label>
                            <input type="text" class="form-control custom-input" id="hp" name="hp" placeholder="010-0000-0000">
                        </div>
                    </form>
                </div>

                <div class="modal-footer d-grid gap-2 w-100 px-4">
                   <button type="button" id="btnJoin" name="btnJoin" class="btn btn-primary btn-lg border-0" style="background-color:#3498db; font-weight: bold;">가입하기</button>
                   <a href="login.do" class="text-center text-decoration-none mt-2" data-bs-dismiss="modal" style="color:#3498db; font-size:14px; font-weight:bold;">로그인하러 가기</a>
                </div>
            </div>
        </div>
    </div>

    <!-- 부트스트랩 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 학생 vs 교수 전환 스크립트
        function switchUserType(type) {

            if (type == "student") {
            	uType = "S";
            	$("#deptArea").removeClass('d-none');
            	$("#idLabel").text('학번');
            	$("#num").attr('placeholder', '학번 8자리를 입력하세요');
            	$("#btnStudent").addClass('active');
            	$("#btnProfessor").removeClass('active');
                $("#btnStudent").find('.dot-icon').css('background', '#333');
                $("#btnProfessor").find('.dot-icon').css('background', 'transparent');
                $("#btnProfessor").find('.dot-icon').css('border', '1px solid #ccc');
            } else {
            	uType = "T";
            	$("#deptArea").addClass('d-none');
                $("#idLabel").text('사번');
                $("#num").attr('placeholder', '사번 8자리를 입력하세요');
                $("#btnProfessor").addClass('active');
                $("#btnStudent").removeClass('active');
                $("#btnProfessor").find('.dot-icon').css('background', '#333');
                $("#btnStudent").find('.dot-icon').css('background', 'transparent');
                $("#btnStudent").find('.dot-icon').css('border', '1px solid #ccc');
            }
        }
    </script>
</body>
</html>