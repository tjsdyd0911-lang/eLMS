<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/teacher/head.jsp" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>
    <div class="main-container">
      <aside>
        <div class="side-menu-top">
         	<a href="../notice/list.do" class="menu-item">공지사항</a>
            <a href="../subject/list.do" class="menu-item">과목 관리</a>
            <a href="list.do?sno=${sno}" class="menu-item active">과제 게시판</a>
        </div>
		<%@ include file="../../include/teacher/side.jsp" %>           
      </aside>
<!-- 
<form id="frmSlist" name="frmSlist" method="post" action="slist.do">
	<input type="hidden" id="sno" name="sno" value="">
	<input type="hidden" id="tno" name="tno" value="">
	<input type="hidden" id="applynow" name="applynow" value="">
	<input type="hidden" id="title" name="title" value="">
</form>
 -->
		<main>
			<script>
			window.onload = function()
			{
				$("td > #spanType").each(function(index, element) 
				{
					type = $(element).text().trim();
					switch(type)
					{
						case "수시과제": $(element).addClass("badge-pill bg-gray");       break;
						case "중간과제": $(element).addClass("badge-pill bg-green-dark"); break;
						case "기말과제": $(element).addClass("badge-pill bg-orange");     break;
					}					
				});
			}
			</script>
			<!-- 1. 페이지 제목 -->
			<div
				class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-2 border-dark">
				<h2 class="m-0 fw-bold text-dark">과제 게시판</h2>
				<button class="btn-batch-approve" onclick="document.location='write.do?sno=${sno}'">
					<i class="fa-solid fa-plus me-1"></i> 과제 등록
				</button>
			</div>
			<div class="divider"></div>
	
			<!-- 2. 서브 헤더 (과목명 + 등록 버튼) -->
			<div class="d-flex justify-content-between align-items-center">
				<h4 class="sub-title">${ title }</h4>
	
			</div>
			<br>
	
			<!-- 3. 테이블 영역 -->
			<div class="table-responsive">
				<table class="table custom-table">
					<colgroup>
						<col style="width: 10%;">
						<!-- 구분 -->
						<col style="width: 35%;">
						<!-- 과제명 -->
						<col style="width: 15%;">
						<!-- 제출 현황 -->
						<col style="width: 15%;">
						<!-- 마감일 -->
						<col style="width: 10%;">
						<!-- 채점 -->
						<col style="width: 15%;">
						<!-- 학생 및 채점현황 -->
					</colgroup>
					<thead>
						<tr>
							<th>구분</th>
							<th>과제명</th>
							<th>제출 현황</th>
							<th>마감일</th>
							<th>채점 현황</th>
							<th>학생 관리</th>
						</tr>
					</thead>
					<tbody>
						<c:forEach var="list" items="${ list }">
							<tr>
								<td><span id="spanType">${list.ttypeName}</span></td>
								<!-- 
								<c:if test="${fn:trim(list.ttype) == '수시과제'}">
									<td><span class="badge-pill bg-gray">수시과제</span></td>
								</c:if>
								<c:if test="${fn:trim(list.ttype) == '중간과제'}">
									<td><span class="badge-pill bg-green-dark">중간과제</span></td>
								</c:if>
								<c:if test="${fn:trim(list.ttype) == '기말과제'}">
									<td><span class="badge-pill bg-orange">기말과제</span></td>
								</c:if>
								 -->
								<td><a href="view.do?tno=${list.tno}">${ list.title }</a></td>
								<td>${ list.submitcount } / ${ list.applynow }</td>
								<td>${ list.edate }</td>
								<td>${ list.scorecount } / ${ list.applynow }</td>
								<td><button class="btn-batch-approve" onclick="document.location='slist.do?tno=${list.tno}&sno=${list.sno}&applynow=${list.applynow}&title=${list.title}'">보기</button></td>
							</tr>
						</c:forEach>
					</tbody>
				</table>
			</div>
	
			<!-- 4. 페이지네이션 -->
			<div class="pagination gap-2" style="text-align: center;">
				<c:if test="${ startbk != 1 }">
					<a href="list.do?sno=${sno}&page=${ startbk - 2 }" class="page-num">◀</a>
				</c:if> 
				<c:forEach var="page" begin="${startbk}" end="${endbk}">
					<c:if test="${ page == pageno }">
						<a href="list.do?sno=${sno}&page=${ page }" class="page-num active">${ page }</a>
					</c:if>
					<c:if test="${ page != pageno }">
						<a href="list.do?sno=${sno}&page=${ page }" class="page-num">${ page }</a>
					</c:if>				
				</c:forEach> 
				<c:if test="${ endbk < maxpage }">
					<a href="list.do?sno=${sno}&page=${ endbk + 1 }" class="page-num">▶</a>
				</c:if>
			</div>
	
		</main>
	</div>
</body>
</html>