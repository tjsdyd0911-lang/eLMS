@Controller
@RequestMapping("/admin")
public class AdminController {

	private static final String uploadPath = "D:\\WorkSpace\\eLMS05\\upload";

	@Autowired
	private AdminService adminService;

	@RequestMapping(value = "/notice/list.do")
	public String noticeList(@RequestParam(defaultValue = "1") int page, 
			@RequestParam(defaultValue = "1")String kind,
			String key,Model model) {
		
		if(key == null) key = "";
		
		List<NoticeVO> list = adminService.NoticeGetList(kind,key,page);

		// 전체 게시물 갯수
		int total = adminService.NoticeGetTotal(kind,key);

		// 최대 페이지
		int maxpage = total / 10;
		if (total % 10 != 0)
			maxpage++;

		// 페이징 블럭 계산 (시작블럭, 끝블럭)
		// 시작블럭 = (현재페이지/10) * 10 + 1
		int startbk = (page / 10) * 10 + 1;
		// 끝블럭 = 시작블럭 + 10 - 1
		int endbk = startbk + 10 - 1;
		// 끝블럭 > 전체페이지 갯수 크면
		if (endbk > maxpage) {
			endbk = maxpage;
		}

		model.addAttribute("list", list);

		// 페이징 처리용 정보를 jsp 전달
		model.addAttribute("total", total);
		model.addAttribute("maxpage", maxpage);

		model.addAttribute("startbk", startbk);
		model.addAttribute("endbk", endbk);

		model.addAttribute("pageno", page);
		model.addAttribute("kind", kind);
		model.addAttribute("key", key);
		

		return "admin/notice/list";
	}

	@RequestMapping(value = "/notice/view.do")
	public String noticeView(@RequestParam(defaultValue = "1") int page, 
			@RequestParam(defaultValue = "1")String kind,
			String key,String no, Model model) {

		if (no == null) {
			// 게시물 번호가 지정 안됨.
			return "redirect:/admin/notice/list.do";
		}
		NoticeVO vo = adminService.NoticeRead(no);
		if (vo == null) {
			// 게시물이 없음
			return "redirect:/admin/notice/list.do";
		}

		model.addAttribute("notice", vo);
		
		model.addAttribute("pageno", page);
		model.addAttribute("kind", kind);
		model.addAttribute("key", key);
		
		return "admin/notice/view";
	}

	// 첨부파일 다운로드
	@RequestMapping(value = "/notice/down.do")
	public void DownLoad(@RequestParam(required = true) String no, HttpServletResponse response) throws IOException {
		// 게시물 정보를 얻는다.
		NoticeVO vo = adminService.NoticeRead(no);

		String originalFileName = vo.getFname();
		String savedFileName = vo.getPname();

		// 첨부파일을 브라우저로 전송한다.
		// originalFileName --> a.jpg
		// savedFileName --> asdf-dasdf-xxdfdf-dd
		// 첨부파일을 읽기하기 위한 객체 생성
		File file = new File(uploadPath, savedFileName);

		// 파일명 인코딩
		String encodedFileName = new String(originalFileName.getBytes("UTF-8"), "ISO-8859-1");

		// 브라우저에게 다운로드 해야 하는 파일이라고 헤더 전송
		response.setContentType("application/download");
		response.setContentLength((int) file.length());
		response.setHeader("Content-Disposition", "attatchment;filename=\"" + encodedFileName + "\"");

		// 실제 파일을 브라우저에 전송
		OutputStream os = response.getOutputStream();

		FileInputStream fis = new FileInputStream(file);
		FileCopyUtils.copy(fis, os);
	}

	@RequestMapping(value = "/notice/write.do")
	public String noticeWrite() {

		return "admin/notice/write";
	}

	@RequestMapping(value = "/notice/writeok.do", method = RequestMethod.POST)
	public String noticeWriteok(NoticeVO vo, @RequestParam("attach") MultipartFile file)
			throws IllegalStateException, IOException {
		if (file != null) {
			// 업로드된 원본 파일 이름 가져오기
			String originalFileName = file.getOriginalFilename();
			System.out.println("업로드한 원래 파일 이름:" + originalFileName);

			UUID uuid = UUID.randomUUID();
			String savedFileName = uuid.toString();
			System.out.println("물리적으로 저장한 파일 이름:" + savedFileName);

			String saveFileName = uploadPath + "\\" + savedFileName;

			File newFile = new File(saveFileName);

			file.transferTo(newFile);

			vo.setFname(originalFileName);
			vo.setPname(savedFileName);
		}
		adminService.NoticeInsert(vo);
		return "redirect:/admin/notice/view.do?no=" + vo.getNno();
	}

	@RequestMapping(value = "/notice/update.do")
	public String noticeUpdate(String no, Model model) 
	{
		if (no == null)
			return "redirect:/admin/notice/list.do";
		NoticeVO vo = adminService.NoticeRead(no);
		
		model.addAttribute("notice", vo);
		return "admin/notice/update";
	}
	
	@RequestMapping(value = "/notice/updateok.do")
	public String noticeUpdateOk(NoticeVO vo,@RequestParam("attach")MultipartFile file, Model model) 
			 throws IllegalStateException, IOException
	{
		
		//첨부파일 있으면 upload 폴더에 저장한다.
		if( file != null )
		{
			//업로드된 원본 파일 이름 가져오기
			String originalFileName = file.getOriginalFilename();
			System.out.println("업로드한 원래 파일 이름:" + originalFileName);
			
			//파일 이름이 중복되지 않도록 파일이름을 변경해서 저장
			//물리 파일이름(savedFileName), 논리파일 이름(originalFileName)
			UUID uuid = UUID.randomUUID();
			String savedFileName = uuid.toString();
			System.out.println("물리적으로 저장한 파일 이름:" + savedFileName);
			
			//첨부파일을 upload 폴더에 저장한다.
			String saveFileName = uploadPath + "\\" + savedFileName;
			//saveFileName<-- upload\a.jpg
			
			//첨부파일을 저장하기 위한 객체 생성
			File newFile = new File(saveFileName);
			
			//실제로 저장한다.
			file.transferTo(newFile);	
			
			vo.setFname(originalFileName); //원본파일명
			vo.setPname(savedFileName);    //저장된 파일명			
		}		
		adminService.NoticeUpdate(vo);
	
		return "redirect:/admin/notice/view.do?no=" + vo.getNno();
	}
	
	@RequestMapping(value = "/notice/delete.do")
	public String NoticeDelete(String no) {
		adminService.NoticeDelete(no);
		return "redirect:/admin/notice/list.do";
	}

	
	@RequestMapping(value = "/teacher/list.do")
	public String teacherList(@RequestParam(defaultValue = "1") int page, Model model) {
		
		// 서비스에 전달할 SearchVO 객체 생성 및 세팅
	    SearchVO svo = new SearchVO();
	    svo.setPageno(page);
	    svo.setStatus("T");
	    
		List<UserVO> list = adminService.TeacherGetList(svo);
		//System.out.println("리스트 개수: " + list.size());
		// 전체 게시물 갯수
		int total = adminService.TeacherGetTotal(svo);

		// 최대 페이지
		int maxpage = total / 10;
		if (total % 10 != 0)
			maxpage++;

		// 페이징 블럭 계산 (시작블럭, 끝블럭)
		// 시작블럭 = (현재페이지/10) * 10 + 1
		int startbk = (page / 10) * 10 + 1;
		// 끝블럭 = 시작블럭 + 10 - 1
		int endbk = startbk + 10 - 1;
		// 끝블럭 > 전체페이지 갯수 크면
		if (endbk > maxpage) {
			endbk = maxpage;
		}

		model.addAttribute("list", list);

		// 페이징 처리용 정보를 jsp 전달
		model.addAttribute("total", total);
		model.addAttribute("maxpage", maxpage);

		model.addAttribute("startbk", startbk);
		model.addAttribute("endbk", endbk);

		model.addAttribute("pageno", page);
		

		return "admin/teacher/list";
	}
	
	// 상태를 변경하는 메서드 (새로 추가)	
	@RequestMapping(value = "/teacher/updateStatus.do", method = RequestMethod.POST)
	@ResponseBody
	public String updateTeacherStatus(String status,String uno) {
	    // service.UpdateTstatus(vo)가 int를 리턴하도록 수정했다면 아래와 같이 작성
		//uno=1,2,3,4 ==> String 배열로 변환
		String []uno_list = uno.split(",");
		UserVO vo = new UserVO();
		for(int i = 0 ; i < uno_list.length; i++)
		{
			vo.setStatus(status);
			vo.setUno(Integer.parseInt(uno_list[i]));
			adminService.TeacherUpdateStatus(vo); // DB 업데이트 실행
		}
		return "OK";
	}
	
	// 교수 승인 처리 (POST 방식)
	@RequestMapping(value = "/teacher/updateAccept.do", method = RequestMethod.POST)
	@ResponseBody
	public String updateTeacherAccept(String uno) {
		//System.out.println("updateTeacherAccept-1");
		//uno=1,2,3,4 ==> String 배열로 변환
		String []uno_list = uno.split(",");
		for(int i = 0 ; i < uno_list.length; i++)
		{
			//System.out.println("updateTeacherAccept-" + uno_list[i]);
			adminService.TeacherApprove(uno_list[i]); // DB 업데이트 실행
		}
		//System.out.println("updateTeacherAccept-ok");
		return "OK";
	}
	
		
