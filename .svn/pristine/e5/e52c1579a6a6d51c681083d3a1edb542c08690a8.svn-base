package com.elms.control;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpSession;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import org.springframework.web.bind.annotation.ResponseBody;

import com.elms.service.UserService;
import com.elms.vo.UserVO;

@Controller
public class UserController {
	
	@Autowired
	private UserService userService;

	//첫페이지
	@RequestMapping(value = "/login.do")
	public String Login() {
		return "user/login";
	}
	
	//로그인-> 각 사용자 메인페이지 이동 
	@RequestMapping(value = "/loginok.do", method = RequestMethod.POST)
	@ResponseBody
	public String LoginOk(String uid, String pw, HttpServletRequest request) {
	   
		HttpSession session = request.getSession();
		
		session.setAttribute("login", null);
		if ( uid == null || pw == null )
		{
			return "error";
		}
		
		//S:학생, T:교사, A:관리자 
		UserVO vo = userService.Login(uid,pw);
		 
		if( vo == null )
		{
			return "error";
		}else if(vo.getAppr().equals("N")) 
		{
			return "WAIT"; 
		}
		else if(vo.getUtype().equals("S"))
		{
			session.setAttribute("login", vo);
			return "S";
		}else if(vo.getUtype().equals("T"))
		{
			session.setAttribute("login", vo);
			return "T";
		}else if(vo.getUtype().equals("A"))
		{
			session.setAttribute("login", vo);
			return "A";
		}else
		{
			return "error";
		}
		
	}
	
	//로그아웃 처리
	@RequestMapping(value="/logout.do")
	public String Logout(HttpServletRequest request){
		HttpSession session = request.getSession();
		session.invalidate(); //로그아웃
		
		return "redirect:/login.do";
	}
	
	//회원가입처리
	@RequestMapping(value = "/joinok.do", method = RequestMethod.POST)
	@ResponseBody
	public String JoinOk(UserVO vo) {
		userService.Join(vo);
		return "OK";
	}
	
	//아이디 중복검사(ajax 실시간)
	@RequestMapping(value = "/checkid.do",  produces = "text/html; charset=utf8")
	@ResponseBody
	public String CheckId(String uid) {
		boolean dupl = userService.CheckID(uid);
		if( dupl ) return "possible";
		else return "impossible";
	}
	
	//학번-사번 중복검사(ajax 실시간)
	@RequestMapping(value = "/checknum.do",  produces = "text/html; charset=utf8")
	@ResponseBody
	public String CheckNum(String num) {
		boolean dupl = userService.CheckNum(num);
		
		if( dupl) return "possible";
		else return "impossible";
	}
	
	//아이디찾기 화면
	@RequestMapping(value = "/id_find.do")
	public String IdFind() {
		return "user/id_find";
	}
	
	//입력정보와 일치하는 아이디 찾는 처리
	@RequestMapping(value = "/id_find_check.do", method = RequestMethod.POST)
	@ResponseBody
	public String IdFindCheck(String num, String name, String hp, String utype) {
		UserVO findId = userService.IdFind(num, name, hp, utype);
		if( findId == null ) {
			return "NONE";
		}
		return "FIND";
	}
	
	//찾은 아이디확인 화면
	@RequestMapping(value = "/id_findok.do",  produces = "text/html; charset=utf8", method = RequestMethod.POST)
	public String IdFindOk(String num, String name, String hp, String utype, Model model) {
		UserVO vo = userService.IdFind(num, name, hp, utype);
		
	    String originalName = vo.getUid(); 
	    if ( originalName == null)
	    {
	    	System.out.println("이메일 : " + vo.getUid());
	    	originalName = "std120@univ.ac.kr";
	    }

	    String maskedId = originalName.replaceAll("^(.{2}).*(@.*)$", "$1***$2");
		
		model.addAttribute("name", vo.getName());
		model.addAttribute("id", vo.getUid());
		model.addAttribute("maskedId", maskedId);
		return "user/id_findok";
	}
	
	//비밀번호찾기 화면
	@RequestMapping(value = "/pw_find.do")
	public String PwFind() {
		return "user/pw_find";
	}
	
	//(비밀번호찾기)입력정보와 일치하는 회원 찾는 처리
	@RequestMapping(value = "/pw_find_check.do", method = RequestMethod.POST)
	@ResponseBody
	public String PwFindCheck(String uid, String num, String name, String hp) {
		UserVO findPw = userService.PwFind(uid, num, name, hp);
		if( findPw == null) {
			return "NONE";
		}
		return "FIND";
	}
	
	//(비밀번호찾기)비밀번호 변경 화면
	@RequestMapping(value = "/pw_findok.do", method = RequestMethod.POST)
	public String PwFindOk(String uid, String num, String name, String hp, Model model) {
		UserVO vo = userService.PwFind(uid, num, name, hp);
		
	    String originalName = vo.getUid(); 
		String maskedId = originalName.replaceAll("^(.{2}).*(@.*)$", "$1***$2");
		   
		model.addAttribute("id", vo.getUid());
		model.addAttribute("maskedId", maskedId);

		return "user/pw_findok";
	}
	
	//(비밀번호찾기)비밀번호 변경 처리
	@RequestMapping(value = "/pw_update.do", method = RequestMethod.POST)
	public String PwUpdate(String uid, String pw) {
		userService.PwUpdate(uid, pw);
		
		return "user/login";
	}
	
}
