package com.elms.control;

import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.io.OutputStream;
import java.util.List;
import java.util.Locale;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;
import javax.servlet.http.HttpSession;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.dao.DataIntegrityViolationException;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.util.FileCopyUtils;
import org.springframework.web.bind.annotation.*;

import com.elms.service.AdminService;
import com.elms.service.StudentService;
import com.elms.service.TeacherService;
import com.elms.util.ConvertUtil;
import com.elms.vo.ApplyVO;
import com.elms.vo.NoticeVO;
import com.elms.vo.SubjectVO;
import com.elms.vo.TaskVO;
import com.elms.vo.UserVO;


@Controller
@RequestMapping("/teacher")
public class TeacherController {

	TeacherService teacherService;
	AdminService adminService;
	
	@Autowired
	public TeacherController(TeacherService teacherService, AdminService adminService) {
		this.teacherService = teacherService;
		this.adminService = adminService;
	}
	
	//공지사항 목록 화면
	@RequestMapping(value = "/notice/list.do")
	public String noticeList(Model model, HttpSession session,
			@RequestParam(defaultValue = "1") int page, 
			@RequestParam(defaultValue = "1")String kind,
			String key) {
		//유저 로그인 확인 여부를 위한 조회
		UserVO login = (UserVO)session.getAttribute("login");
		//로그인 정보 없으면 로그인 페이지로 이동
		if(login == null) return "redirect:/login.do";
		
		if(key == null) key = "";
		
		List<NoticeVO> list = adminService.NoticeGetList(kind,key,page);

		// 전체 게시물 갯수
		int total = adminService.NoticeGetTotal(kind,key);

		// 최대 페이지
		int maxpage = total / 10;
		if (total % 10 != 0)
			maxpage++;

		// 페이징 블럭 계산 (시작블럭, 끝블럭)
		// 시작블럭 = (현재페이지/10) * 10 + 1
		int startbk = (page / 10) * 10 + 1;
		// 끝블럭 = 시작블럭 + 10 - 1
		int endbk = startbk + 10 - 1;
		// 끝블럭 > 전체페이지 갯수 크면
		if (endbk > maxpage) {
			endbk = maxpage;
		}

		model.addAttribute("list", list);

		// 페이징 처리용 정보를 jsp 전달
		model.addAttribute("total", total);
		model.addAttribute("maxpage", maxpage);

		model.addAttribute("startbk", startbk);
		model.addAttribute("endbk", endbk);

		model.addAttribute("pageno", page);
		model.addAttribute("kind", kind);
		model.addAttribute("key", key);

		return "teacher/notice/list";
	}
	
	//공지사항 보기 화면
	@RequestMapping(value = "/notice/view.do")
	public String noticeView() {
		return "teacher/notice/view";
	}
	
	//과목게시판 페이지
	@RequestMapping(value = "/subject/list.do")
	public String subjectList(@RequestParam(defaultValue = "1") int page, Model model, HttpSession session) {
		UserVO login = (UserVO)session.getAttribute("login");
		
		//과목목록
		List<SubjectVO> list = teacherService.subjectList(login.getUno(), page);
		
		//생성한 과목 조회
		List<SubjectVO> subject = teacherService.MySubject(login.getUno());
		session.setAttribute("subject", subject);

		// 전체 게시물 갯수
		int total = teacherService.SubjectGetTotal(login.getUno());

		// 최대 페이지
		int maxpage = total / 5;
		if (total % 5 != 0)
			maxpage++;

		int startbk = (page / 5) * 5 + 1;

		int endbk = startbk + 5 - 1;
		
		if (endbk > maxpage) {
			endbk = maxpage;
		}
		
		//list 각각의 과목객체에 수강신청인원 수 저장
		if (list != null && !list.isEmpty()) {
			for(SubjectVO subjects : list) {
			    int count = teacherService.ApplyCount(subjects.getSno());
			    subjects.setApplynow(count); // VO에 applynow 객체 추가
			}
		}else {
			return "teacher/subject/list";	
		}
		
		model.addAttribute("list", list);
		
		// 페이징 처리용 정보를 jsp 전달
		model.addAttribute("maxpage", maxpage);
		model.addAttribute("startbk", startbk);
		model.addAttribute("endbk", endbk);
		model.addAttribute("pageno", page);
		return "teacher/subject/list";
	}
	
	//과제리스트 목록
	@RequestMapping(value = "/task/list.do")
	public String taskList(int sno, String sname, Model model, 
							@RequestParam(defaultValue = "1") int page,
							HttpSession session) {
		//유저 로그인 확인 여부를 위한 조회
		UserVO login = (UserVO)session.getAttribute("login");
		//로그인 정보 없으면 로그인 페이지로 이동
		if(login == null) return "redirect:/login.do";
		
		//과제목록
		List<TaskVO> list = teacherService.taskList(sno, page);
		
		//생성한 과목 조회
		List<SubjectVO> subject = teacherService.MySubject(login.getUno());
		session.setAttribute("subject", subject);
		
		// 전체 게시물 갯수
		int total = teacherService.TaskGetTotal(sno);

		// 최대 페이지
		int maxpage = total / 5;
		if (total % 5 != 0)
			maxpage++;

		int startbk = (page / 5) * 5 + 1;

		int endbk = startbk + 5 - 1;
		
		if (endbk > maxpage) {
			endbk = maxpage;
		}
		
		//list 각각의 과제객체에 제출-채점현황수(수강신청인원수) 저장
		if (list != null && !list.isEmpty()) {
			for(TaskVO task : list) {
			    int count = teacherService.ApplyCount(task.getSno());
			    task.setApplynow(count); // VO에 applynow 객체 추가
			}
		}else {
			return "teacher/task/list";	
		}
		
		model.addAttribute("title", sname);
		model.addAttribute("list", list);
		
		// 페이징 처리용 정보를 jsp 전달
		model.addAttribute("maxpage", maxpage);
		model.addAttribute("startbk", startbk);
		model.addAttribute("endbk", endbk);
		model.addAttribute("pageno", page);
		
		return "teacher/task/list";
	}
	
	//학생리스트 및 채점모달 목록 화면
	@RequestMapping(value = "/task/slist.do")
	public String taskSlist() {
		return "teacher/task/slist";
	}
	
	//과제작성 화면
	@RequestMapping(value = "/task/write.do")
	public String taskWrite() {
		return "teacher/task/write";
	}
	
	//과제보기 화면
	@RequestMapping(value = "/task/view.do")
	public String taskView(int tno, Model model) {
		TaskVO vo = teacherService.taskView(tno);
		
		model.addAttribute("view",vo);
		
		return "teacher/task/view";
	}	

	//회원정보수정 비밀번호 입력 화면
	@RequestMapping(value = "/user/update.do")
	public String userUpdate() {
		return "teacher/user/update";
	}
	
	//회원정보수정 비밀번호 일치 확인 처리
	@RequestMapping(value = "/user/pwmatch.do", method = RequestMethod.POST)
	@ResponseBody
	public String PwMatch(String id, String pw, HttpSession session) {
		UserVO login = (UserVO)session.getAttribute("login");
		
		if(login == null) return "redirect:/user/login.do";
		boolean match = teacherService.PwMatch(id, pw);
		if( match == true) {
			return "O";
		}else {
			return "X";
		}
	}
	
	//회원정보 수정 화면
	@RequestMapping(value = "/user/updateok.do")
	public String Updateok(String uid, Model model) {
		UserVO vo = new UserVO();
		vo.setUid(uid);
		UserVO UserInfo = teacherService.UserInfo(vo);
		
		model.addAttribute("num", UserInfo.getNum());
		model.addAttribute("name", UserInfo.getName());
		model.addAttribute("id", UserInfo.getUid());
		model.addAttribute("hp", UserInfo.getHp());
		return "teacher/user/updateok";
	}
	
	//회원정보 수정 처리
	@RequestMapping(value = "/user/infoupdate.do", method = RequestMethod.POST)
	@ResponseBody
	public String InfoUpdate(String id, String hp, String pw) {
		teacherService.InfoUpdate(id, hp, pw);
		return "OK";
	}
	
	//과목이름 중복검사 처리
	@RequestMapping(value = "/subject/sname_check.do", method = RequestMethod.POST)
	@ResponseBody
	public String SnameCheck(String sname) {
		boolean check = teacherService.SnameCheck(sname);
		if( check == true) {
			return "OK";
		}
		return "NO";
	}
	
	
	//과목 등록 처리
	@RequestMapping(value = "/subject/subjectok.do", method = RequestMethod.POST)
	@ResponseBody
	public String SubjectOk(SubjectVO vo) {
		teacherService.SubjectOk(vo);
		return "OK";
	}
	
	
	//과목 삭제 처리
	@RequestMapping(value = "/subject/subject_del.do/{sno}", method = RequestMethod.DELETE, produces = "text/plain; charset=UTF-8")
	@ResponseBody
	public ResponseEntity<String> SubjectDel(@PathVariable String sno) {
		System.out.println("넘어온 sno: " + sno);
		try {
			teacherService.SubjectDel(sno);
			return new ResponseEntity<String>("삭제되었습니다.", HttpStatus.OK);
		}catch (DataIntegrityViolationException e) {
            // 외래키 제약조건 위반 시 409 Conflict 반환
            return new ResponseEntity<String>("해당 과목을 수강신청한 학생이 있습니다.", HttpStatus.CONFLICT);
                                
        } catch (Exception e) {
            // 그 외 알 수 없는 에러는 500 에러 반환
            return new ResponseEntity<String>("삭제실패 : 재시도 또는 관리자에게 문의하세요.", HttpStatus.INTERNAL_SERVER_ERROR);
        }
		
	}
	
	
	//과목 수정 모달 화면
	@RequestMapping(value = "/subject/subject_update.do", method = RequestMethod.POST, produces = "text/plain; charset=UTF-8")
	@ResponseBody
	public String SubjectUpdate(int uno, int sno) {
		SubjectVO vo = teacherService.SubjectSearch(uno, sno);

		//Json 변환처리
		return ConvertUtil.toJson(vo);
	}
	
	//과목 수정 처리
	@RequestMapping(value = "/subject/subject_updateok.do", method = RequestMethod.POST)
	@ResponseBody
	public String SubjectUpdateOk(SubjectVO vo) {
		teacherService.SubjectUpdate(vo);
		return "OK";
	}
	
}
