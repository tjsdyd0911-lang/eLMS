<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/teacher/head.jsp" %>
    <div class="main-container">
      <aside>
        <div class="side-menu-top">
         	<a href="../notice/list.jsp" class="menu-item">공지사항</a>
            <a href="../subject/list.jsp" class="menu-item">과목 관리</a>
            <a href="../task/list.jsp" class="menu-item active">과제 게시판</a>
        </div>
<%@ include file="../../include/teacher/side.jsp" %>           
      </aside>

	    <main>
            <!-- Breadcrumb 및 제목 한 줄 배치 규격 -->
            <div class="content-header">
                <h2 class="content-title">과제 등록</h2>
                <nav aria-label="breadcrumb">
                    <div class="breadcrumb">
                       <a href="list.jsp"> 과제관리 &nbsp; </a> > &nbsp;  <span>과제등록</span>
                    </div>
                </nav>
            </div>
            <hr class="view-divider">

            <div class="submit-card">
                <form>
                
                      <div class="row info-row">
                        <div class="col-md-4">
                            <label class="form-label">과목명</label>
  							자바 프로그래밍 입문
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">과제명</label>
                            클래스와 상속의 이해 실습 과제
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">마감일</label>
                            2026-06-10
                        </div>
                    </div>
                	<br>
                	<br>
                    <!-- 과제 제목 -->
                    <div class="form-group">
                        <label class="form-label">과제 제목</label>
                        <input type="text" class="form-control custom-input" placeholder="제출할 과제의 제목을 입력하세요.">
                    </div>

                    <!-- 첨부 파일 -->
                    <div class="form-group">
                        <label class="form-label">첨부 파일 <span class="sub-text">최대 50MB까지 가능합니다.</span></label>
                        <input type="file" class="form-control custom-input">
                    </div>

                    <!-- 과제 내용 -->
                    <div class="form-group">
                        <label class="form-label">과제 내용</label>
                        <textarea class="form-control custom-input" placeholder="과제에 대한 보충 설명이나 내용을 입력하세요"></textarea>
                    </div>

                    <!-- 버튼 영역 -->
                    <div class="d-flex justify-content-center">
                        <a href="view.jsp"><button type="button" class="btn-batch-approve">등록</button></a>&nbsp;
                        <a href="list.jsp"><button type="button" class="btn-batch-cancel">취소</button></a>
                    </div>
                </form>
            </div>
        </main>
	</div>

	<!-- Bootstrap JS -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>