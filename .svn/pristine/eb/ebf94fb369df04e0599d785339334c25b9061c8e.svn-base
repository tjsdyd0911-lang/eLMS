<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ include file="../../include/admin/head.jsp"%>

<script>
	window.onload = function() {
		$("#title").focus();

		$("#btnSave").click(function() {
			DoSubmit();
		});

		$("#btnCancel").click(function() {
			document.location = "view.do?no=${ notice.nno }";
		});
	}

	function DoSubmit() {
		if ($("#title").val() == "") {
			alert("제목을 입력하세요.");
			$("#title").focus();
			return;
		}
		if ($("#content").val() == "") {
			alert("내용을 입력하세요.");
			$("#content").focus();
			return;
		}
		
		if (confirm("게시물을 변경하시겠습니까?") == true) {
			$("#update").submit();
		}

	}
</script>
<div class="main-container">
	<aside>
		<div class="side-menu-top">
			<a href="../notice/list.do" class="menu-item active">공지사항</a> <a href="../teacher/list.do" class="menu-item">교사 관리</a> <a href="../student/list.do" class="menu-item">학생 관리</a>
		</div>
	</aside>
	<!-- 본문 내용 -->
	<main class="content-area">
		<!-- 페이지 헤더 -->
		<div class="page-header">
			<h2 class="page-title">공지사항 수정</h2>
			<nav aria-label="breadcrumb">
				<div class="breadcrumb">
					<a href="list.do"> 공지사항 &nbsp; </a> > &nbsp; <a href="view.do"> 공지사항 보기 &nbsp; </a> > &nbsp; <span>공지사항 수정</span>
				</div>
			</nav>
		</div>

		<!-- 공지사항 수정 폼 -->
		<form id="update" name="update" action="updateok.do" method="post" enctype="multipart/form-data">
			<input type="hidden" id="nno" name="nno" value="${ notice.nno }">
			<!-- 제목 -->
			<label class="form-label">제목</label> <input type="text" class="form-control-custom" id="title" name="title" value="${ notice.title }">

			<!-- 내용 -->
			<label class="form-label">내용</label>
			<textarea class="form-control-custom" id="content" name="content" style="height: 320px;">${ notice.content }</textarea>

			<!-- 구분선 (이미지와 동일하게 추가) -->
			<hr style="border-top: 1px solid #dee2e6; margin: 10px 0;">
			<!-- 첨부파일 -->
			<label class="form-label">첨부파일</label>
			<div class="file-upload-box">
				<i class="fa-solid fa-paperclip file-icon"></i>
				<div>
					<input type="file" id="fileInput" name="attach">
				</div>
			</div>
			<div>
				<c:choose>
					<c:when test="${ notice.fname != null and !notice.fname.equals('') }">
						<a href="down.do?no=${ notice.nno }">${ notice.fname }</a>
					</c:when>
					<c:otherwise>
					등록된 첨부파일이 없습니다.
				</c:otherwise>
				</c:choose>
			</div>
			<!-- 버튼 영역 (이미지상 우측 정렬) -->
			<div class="text-end">
				<button type="button" id="btnSave" class="btn-custom btn-blue">수정 완료</button>
				<button type="button" id="btnCancel" class="btn-custom btn-grey" onclick="history.back()">취소</button>
			</div>
		</form>
	</main>
</div>

<!-- 부트스트랩 JS (필요시) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>