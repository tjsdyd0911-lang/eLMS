package com.elms.vo;

public class SearchVO 
{
	private int    pageno; //현재 페이지 번호
	private int    offset; //limit 시작 번호
	
	//공지사항 목록 검색 전용으로 사용
	private String kind;   //1:제목,2:제목+내용
	private String key;    //검색 키워드
	
	//status=T-교사목록 조회,S-학생목록 조회
	private String status; 

	//교사 본인 과목만 불러오기 위해서 사용
	private int uno;
	
	public SearchVO()
	{
		kind   = "";
		key    = "";
		status = "T"; //교사검색 기본
	}
	
	public int    getPageno() {	return pageno; }
	public int    getOffset() { return offset; }
	public String getKind()   { return kind;   }
	public String getKey()    { return key;    }
	public String getStatus() { return status; }
	public int    getUno()    { return uno;    }
	
	public void setPageno(int pageno) 
	{	
		this.pageno = pageno; 
		this.offset = (pageno - 1) * 5;
	}
	public void setKind(String kind)     { this.kind = kind;    }
	public void setKey(String key)       { this.key = key;      }
	public void setStatus(String status) { this.status = status;}
	public void setUno(int uno)          { this.uno = uno;      }
}