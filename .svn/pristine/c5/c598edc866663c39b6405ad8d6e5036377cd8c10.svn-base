<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/student/head.jsp"%>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<script>
window.onload = function()
{
	
	var stype = "${ task.stype }";
	var score = "${ submission.score }";
	var scheck = "${ submission.scheck }";
	if(scheck == 'Y'){
		switch(stype){
			case "01" : 
				$(".score-value").text(score + " / 100");
				break;
			case "02" :
				$(".score-value").text(score);
				break;
			default :
				$(".score-value").text("-");
				break;
		}
	}
	
	$("#btn-edit").click(function(){
		DoEdit();
	});
	$("#btn-delete").click(function(){
		DoDelete();
	});
	
}

function DoEdit(){
	document.location = "update.do?sno=${ task.sno }&tno=${ submission.tno }";
}
function DoDelete(){
	if(confirm("과제를 삭제 하시겠습니까?") == true){
		document.location = "delete.do?tno=${ submission.tno }";		
	}
}
</script>
    <div class="main-container">
        <aside>
            <div class="side-menu-top">
             	<a href="../notice/list.do" class="menu-item">공지사항</a>
                <a href="../apply/apply.do" class="menu-item">수강 신청</a>
                <a href="../task/list.do" class="menu-item active">과제 관리</a>
            </div>
 <%@ include file="../../include/student/side.jsp"%>           
        </aside>
        
        <main>
            <!-- Breadcrumb 및 제목 -->
            <div class="content-header">
                <h2 class="content-title">과제 상세보기</h2>
                <nav aria-label="breadcrumb">
                    <div class="breadcrumb">
                         <a href="list.do"> 과제관리 &nbsp; </a> > &nbsp; <span>과제상세보기</span>
                    </div>
                </nav>
            </div>
            
            <!-- 명확해진 hr 구분선 -->
             <hr class="view-divider">

            <!-- [폭이 조정된] 과제 상세 내용 카드 -->
            <div class="detail-card">
                <div class="task-badge">${ submission.sname }</div>
                    <i class="fa-solid fa-caret-right"></i>
                <div class="subject-badge">${ submission.ttitle }</div>
                <h1 class="detail-main-title">${ submission.title }</h1>
                <div class="detail-meta">
                    <span>제출일 : ${ submission.smdate }</span>
                    <span>제출자 : ${ submission.name } (${ submission.num })</span>
                </div>

                <div class="detail-content">${ submission.content }</div>

                <div class="attachment-bar">
                    <div class="file-info">
                        <span class="file-name">${ submission.fname }</span>
                        <span class="file-size">${ submission.fsize } </span>
                    </div>
                    <c:if test="${not empty submission.pname}">
                    	<button class="btn-download" onclick="location.href='down.do?type=1&smno=${submission.smno}'">다운로드</button>
                    </c:if>
                </div>

                <div class="feedback-section">
                    <div class="feedback-header">
                        <div class="feedback-title">교수님 평가 및 피드백</div>
                        <div class="score-box">
                            <div class="score-label">FINAL SCORE</div>
                            <div class="score-value"></div>
                        </div>
                    </div>
                    <!-- 피드백 내용 -->
                    <div class="feedback-content">${ submission.feedback }</div>

                    <div class="attachment-bar" style="background-color: #fbfbfb;">
                        <div class="file-info">
                            <span class="file-name" style="color: #bbb;">${ submission.ffname }</span>
                        	<span class="file-size">${ submission.ffsize }</span>
                        </div>
						<c:if test="${not empty submission.fpname}">
							<button class="btn-download" onclick="location.href='down.do?type=2&smno=${submission.smno}'">다운로드</button>
						</c:if>
                    </div>
                </div>
            </div>

            <!-- 하단 버튼 영역 -->
            <jsp:useBean id="now" class="java.util.Date"/>
            <fmt:formatDate value="${ now }" pattern="yyyyMMdd" var="today"/>
            <div class="detail-footer">
                <a href="list.do"><button class="btn-custom btn-list">목록으로</button></a>
	            <c:if test="${ submission.scheck == 'N' && fn:replace(task.edate, '-','') > today }">    
	                <button id="btn-edit" class="btn-custom btn-edit">수정</button>
	                <button id="btn-delete" class="btn-custom btn-delete">삭제</button>
            	</c:if>
            </div>

        </main>
    </div>
</body>
</html>