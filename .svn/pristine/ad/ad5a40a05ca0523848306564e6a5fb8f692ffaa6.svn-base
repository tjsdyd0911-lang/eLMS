<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<%@ include file="../../include/admin/head.jsp" %>
    <div class="main-container">
        <aside>
            <div class="side-menu-top">
                <a href="../notice/list.do" class="menu-item">공지사항</a>
                <a href="../teacher/list.do" class="menu-item">교사 관리</a>
                <a href="../student/list.do" class="menu-item active">학생 관리</a>
            </div>
        </aside>
		<!-- 본문 내용 -->
		<main class="content-area">
			<!-- 상단 제목 및 버튼 -->
			<div class="d-flex justify-content-between align-items-center">
				<h2 class="page-title">학생 관리</h2>
				<div class="d-flex gap-2">
					<select class="form-select form-select-sm">
						<option selected>상태변경</option>
						<option value="1">재학</option>
						<option value="2">휴학</option>
						<option value="3">제적</option>
					</select>
					<button class="btn-top-green">변경사항 저장</button>				
				</div>
			</div>

			<!-- 구분선 -->
			<hr style="border-top: 1px solid #dee2e6; margin-bottom: 0;">
			
			<!-- 테이블 -->
			<table class="custom-table">
				<colgroup>
					<col style="width: 5%;">
					<col style="width: 10%;">
					<col style="width: 15%;">
					<col style="width: 15%;">
					<col style="width: 20%;">
					<col style="width: 20%;">
					<col style="width: 15%;">
				</colgroup>
				<thead>
					<tr>
						<th><input type="checkbox" class="form-check-input"></th>
						<th>번호</th>
						<th>학번</th>
						<th>이름</th>
						<th>학과</th>
						<th>가입일</th>
						<th>현재상태</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td><input type="checkbox" class="form-check-input"></td>
						<td>182</td>
						<td>s12345</td>
						<td>홍길동</td>
						<td>컴퓨터공학과</td>
						<td>2024-05-15</td>
						<td><span class="badge-status status-enrolled">재학</span></td>
					</tr>
					<tr>
						<td><input type="checkbox" class="form-check-input"></td>
						<td>181</td>
						<td>s12548</td>
						<td>강감찬</td>
						<td>데이터분석과</td>
						<td>2024-05-12</td>
						<td><span class="badge-status status-leave">휴학</span></td>
					</tr>
					<tr>
						<td><input type="checkbox" class="form-check-input"></td>
						<td>180</td>
						<td>s25878</td>
						<td>유관순</td>
						<td>정보통신학과</td>
						<td>2024-05-01</td>
						<td><span class="badge-status status-expelled">제적</span></td>
					</tr>
				</tbody>
			</table>

			<!-- 하단 페이지네이션 및 버튼 -->
            <div class="pagination gap-2">
            	<a href="list.do" class="page-num">◀</a>
                <a href="list.do" class="page-num choice">1</a>
                <a href="list.do" class="page-num">2</a>
                <a href="list.do" class="page-num">3</a>
                <a href="list.do" class="page-num">4</a>
                <a href="list.do" class="page-num">5</a>
                <a href="list.do" class="page-num">▶</a>
            </div>
		</main>
	</div>

	<!-- 부트스트랩 JS (필요시) -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>