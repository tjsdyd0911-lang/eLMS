// 클래스 : 게시물정보 C/R/U/D 처리 클래스
package com.elms.service;

import java.util.List;

import org.apache.ibatis.session.SqlSession;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.elms.vo.*;

@Service
public class AdminService {
	@Autowired
	private SqlSession session;

	private static final String namespace = "elms.notice";

	// 게시물을 등록한다.
	// return true : 등록 성공, false : 등록 실패
	public boolean Insert(NoticeVO vo) {
		session.insert(namespace + ".write", vo);
		return true;
	}

	public NoticeVO Read(String Nno) {
		NoticeVO vo = session.selectOne(namespace + ".view", Nno);
		return vo;
	}

	// 게시물 정보를 변경한다.
	// return true : 변경 성공, false : 변경 실패
	public void Update(NoticeVO vo) {
		session.update(namespace + ".update", vo);
	}
	
	public void delete(String no) {
		session.update(namespace + ".delete", no);
	}

	// 전체 게시물 갯수를 얻는다.

	public int GetTotal(String kind,String key) {
		SearchVO vo = new SearchVO();
		vo.setKind(kind);
		vo.setKey(key);
		
		int total = session.selectOne(namespace + ".total", vo);
		return total;
	}

	// 게시물 목록을 얻는다.
	// pageno : 페이지 번호
	public List<NoticeVO> GetList(String kind,String key,int pageno) {
		SearchVO vo = new SearchVO();
		vo.setKind(kind);
		vo.setKey(key);

		vo.setPageno(pageno);

		List<NoticeVO> list = session.selectList(namespace + ".list", vo);
		return list;
	}
}