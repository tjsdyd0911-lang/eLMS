<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/admin/head.jsp" %>
  <div class="main-container">
        <aside>
            <div class="side-menu-top">
                <a href="../notice/list.do" class="menu-item active">공지사항</a>
                <a href="../teacher/list.do" class="menu-item">교사 관리</a>
                <a href="../student/list.do" class="menu-item">학생 관리</a>
            </div>
        </aside>
		<!-- 본문 내용 -->
        <main>
            <div class="content-header">
                <h2 id="title" name="title" class="view-title">${ notice.title }</h2>
                <nav aria-label="breadcrumb">
                    <div class="breadcrumb">
                       <a href="list.do"> 공지사항 &nbsp; </a> > &nbsp;  <span>국가장학금 공지</span>
                    </div>
                </nav>
            </div>

            <div class="view-meta">
                <span><b>번호</b> ${ notice.nno }</span>
                <span><b>작성일</b> ${ notice.wdate }</span>
                <span><b>작성자</b> 관리자</span>
            </div>
            
            <hr class="view-divider">

            <div id="content" name="content" class="view-content">
                ${ notice.content }<br>
            </div>

            <div class="view-footer">
                <button type="button" class="btn-list" onclick="document.location='list.do'">목록으로</button>&nbsp;&nbsp;
                <button class="btn-apply" onclick="document.location='update.do'">수정</button>&nbsp;&nbsp;
                <button class="btn-delete" onclick="document.location='list.do'">삭제</button>
            </div>
        </main>
    </div>

</body>
</html>