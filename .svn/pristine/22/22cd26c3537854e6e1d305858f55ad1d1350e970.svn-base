<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/teacher/head.jsp" %>
    <div class="main-container">
      <aside>
        <div class="side-menu-top">
         	<a href="../notice/list.do" class="menu-item">공지사항</a>
            <a href="../subject/list.do" class="menu-item">과목 관리</a>
            <a href="../task/list.do" class="menu-item active">과제 게시판</a>
        </div>
<%@ include file="../../include/teacher/side.jsp" %>           
      </aside>

		<main>
			<!-- 1. 페이지 제목 -->
			<div class="d-flex justify-content-between align-items-end">
				<h2 class="m-0 fw-bold text-dark">웹디자인실습</h2>
				<nav class="breadcrumb">
					<a href="list.do">과제 게시판  &nbsp; </a> >  &nbsp;<span>학생 및 채점현황</span>
				</nav>

			</div>
			
			<br>
			<!-- 2. 상단 상태바 (제목 + 브레드크럼) -->
			<h6 style="text-align:right;">수강 학생 채점 현황 (총 50명)</h6>

			<div class="task-divider"></div>

			<!-- 3. 학생 목록 테이블 -->
			<div class="table-responsive">
				<table class="table task-custom-table table-hover">
					<thead>
						<tr>
							<th style="width: 8%;">번호</th>
							<th style="width: 15%;">학번</th>
							<th style="width: 15%;">이름</th>
							<th style="width: 20%;">학과</th>
							<th style="width: 12%;">채점</th>
							<th style="width: 30%;">점수 (100점 만점)</th>
						</tr>
					</thead>
					<tbody>
						<!-- 반복 요소 예시 (이미지 데이터 기준) -->
						<tr>
							<td>1</td>
							<td>20240001</td>
							<td>학생1</td>
							<td>컴퓨터공학</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">78점</span></td>
						</tr>
						<tr>
							<td>2</td>
							<td>20240002</td>
							<td>학생2</td>
							<td>시각디자인</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">82점</span></td>
						</tr>
						<tr>
							<td>3</td>
							<td>20240003</td>
							<td>학생3</td>
							<td>컴퓨터공학</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">97점</span></td>
						</tr>
						<tr>
							<td>4</td>
							<td>20240004</td>
							<td>학생4</td>
							<td>시각디자인</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">96점</span></td>
						</tr>
						<tr>
							<td>5</td>
							<td>20240005</td>
							<td>학생5</td>
							<td>컴퓨터공학</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">88점</span></td>
						</tr>
						<!-- ... 추가 데이터 ... -->
						<tr>
							<td>10</td>
							<td>20240010</td>
							<td>학생10</td>
							<td>시각디자인</td>
							<td><button class="btn-batch-approve" data-bs-toggle="modal"
									data-bs-target="#gradingModal">채점</button></td>
							<td><span class="task-score-text">90점</span></td>
						</tr>
					</tbody>
				</table>
			</div>

			<!-- 4. 페이지네이션 -->
            <div class="pagination gap-2">
            	<a href="slist.do" class="page-num">◀</a>
                <a href="slist.do" class="page-num choice">1</a>
                <a href="slist.do" class="page-num">2</a>
                <a href="slist.do" class="page-num">3</a>
                <a href="slist.do" class="page-num">4</a>
                <a href="slist.do" class="page-num">5</a>
                <a href="slist.do" class="page-num">▶</a>
            </div>

			<!-- 5. 하단 버튼 영역 -->
			<div
				class="task-footer-btns d-flex justify-content-center gap-3 mt-4">
				<button class="btn-green"
					onclick="location.href='../subject/list.do'">과목관리</button>
				<button class="btn-green"
					onclick="location.href='list.do'">과제게시판</button>
			</div>
		</main>
	</div>

	<!-- [MODAL] 채점 및 피드백 모달 -->
	<div class="modal fade" id="gradingModal" tabindex="-1"
		aria-labelledby="gradingModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-xl modal-dialog-centered">
			<div class="modal-content task-modal-content">
				<!-- 모달 헤더: 제목 표시 -->
				<div class="modal-header border-0 pb-0">
					<h4 class="modal-title" id="editModalLabel">과제 채점 및 피드백</h4>
					<button type="button" class="btn-close" data-bs-dismiss="modal"
						aria-label="Close"></button>
				</div>
				<div class="modal-body p-0">
					<div class="d-flex task-modal-container">
						<!-- [좌측] 학생 목록 영역 -->
						<div class="task-modal-sidebar">
							<div class="task-sidebar-header">학생 목록 (총 10명)</div>
							<ul class="task-student-list">
								<li class="task-student-item active">
									<div class="task-student-info">
										<span class="task-student-name">홍길동 (20240123)</span>
									</div> <span class="task-badge-submitted">제출완료</span>
								</li>
								<li class="task-student-item">
									<div class="task-student-info">
										<span class="task-student-name">김철수 (20240015)</span>
									</div> <span class="task-badge-submitted">제출완료</span>
								</li>
								<li class="task-student-item">
									<div class="task-student-info">
										<span class="task-student-name">이영희 (20240082)</span>
									</div> <span class="task-badge-missing">미제출</span>
								</li>
							</ul>
						</div>

						<!-- [우측] 채점 상세 영역 -->
						<div class="task-modal-grading-area">
							<!-- 과제 정보 태그 -->
							<div class="mb-2">
								<span class="task-tag-blue">웹디자인실습</span> <span
									class="task-tag-green">중간과제</span>
							</div>
							<h4 class="task-modal-subject">개인 웹사이트 테마 선정 및 기획안</h4>
							<p class="task-modal-meta">제출일: 2024-05-18 14:20 | 제출자: 홍길동
								(20240123)</p>

							<!-- 학생 제출 내용 -->
							<div class="task-submission-box">과제 제출입니다.</div>

							<!-- 첨부 파일 바 -->
							<div
								class="task-file-bar d-flex justify-content-between align-items-center">
								<span class="task-file-name">홍길동_기획서.pdf</span>
								<div class="task-file-btns">
									<button class="btn task-btn-outline"
										onclick="togglePdfPreview()">문서 미리보기</button>
									<button class="btn task-btn-outline">다운로드</button>
								</div>
							</div>

							<hr class="task-modal-divider">

							<!-- [추가] PDF 미리보기 컨테이너 (기본은 display: none) -->
							<div id="pdfPreviewContainer" class="task-pdf-preview-area"
								style="display: none;">
								<div
									class="d-flex justify-content-between align-items-center bg-light p-2 border-bottom">
									<span class="small fw-bold text-secondary"><i
										class="fa-solid fa-eye me-1"></i>미리보기 중: temp.pdf</span>
									<button type="button" class="btn-close small"
										style="font-size: 10px;" onclick="togglePdfPreview()"></button>
								</div>
								<!-- 실제 PDF가 출력되는 iframe -->
								<iframe id="pdfFrame" src="../../upload/temp.pdf" width="100%"
									height="450px" frameborder="0"></iframe>
							</div>

							<!-- 채점 폼 -->
							<h5 class="task-form-title">과제 채점 및 피드백</h5>
							<div class="row g-3">
								<div class="col-md-6">
									<label class="task-label">점수 산정 방식</label> <input type="text"
										class="form-control task-input" value="점수 입력" readonly>
								</div>
								<div class="col-md-6">
									<label class="task-label">최종 점수</label> <input type="text"
										class="form-control task-input-gray" placeholder="100점 만점">
								</div>
								<div class="col-12">
									<label class="task-label">피드백</label>
									<textarea class="form-control task-textarea" rows="3"
										placeholder="피드백 입력"></textarea>
								</div>
								<div class="col-12">
									<label class="task-label">첨부 파일</label>
									<div class="task-upload-box">
										<input type="file" id="taskFile" hidden> <label
											for="taskFile" class="btn task-btn-file">Choose Files</label>
										<span class="ms-2">No file chosen</span>
									</div>
								</div>
							</div>

							<!-- 최종 저장 버튼 -->
							<button type="button" class="btn task-btn-submit w-100 mt-4">평가
								결과 저장 및 전송</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		function togglePdfPreview() {
			const previewContainer = document
					.getElementById('pdfPreviewContainer');
			const pdfFrame = document.getElementById('pdfFrame');

			// 현재 숨겨져 있으면 보이고, 보이고 있으면 숨김
			if (previewContainer.style.display === 'none') {
				previewContainer.style.display = 'block';
				// iframe의 src를 다시 설정하여 로딩을 확실히 함 (필요시)
				// pdfFrame.src = 'temp.pdf'; 
			} else {
				previewContainer.style.display = 'none';
			}
		}

		// 모달이 닫힐 때 미리보기도 같이 닫히도록 설정 (Bootstrap 이벤트 활용)
		const gradingModal = document.getElementById('gradingModal');
		gradingModal
				.addEventListener(
						'hidden.bs.modal',
						function() {
							document.getElementById('pdfPreviewContainer').style.display = 'none';
						});
	</script>
	<!-- [Bootstrap 5 JS Bundle] -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>