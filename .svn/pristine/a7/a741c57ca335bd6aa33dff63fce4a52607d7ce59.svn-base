<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="elms.student">
	<select id="match" parameterType="com.elms.vo.UserVO" resultType="java.lang.Integer">
		select count(*) from user 
		where uid = #{uid} and pw = md5(#{pw})
	</select>
	
	<select id="info" parameterType="com.elms.vo.UserVO" resultType="com.elms.vo.UserVO">
		select * from user where uid = #{uid}
	</select>
	
	<update id="update" parameterType="com.elms.vo.UserVO">
		update user 
		set hp = #{hp}, pw = md5(#{pw}) 
		where uid = #{uid}
	</update>
	
	<!-- 과목 전체 조회 -->
	<select id="selectlist" resultType="com.elms.vo.SubjectVO">
		select s.sno, s.sname, s.uno, s.cnt,
			u.name as uname, 
			date_format(s.astart, '%Y-%m-%d') as astart, 
	        date_format(s.aend, '%Y-%m-%d') as aend, 
	        date_format(s.sstart, '%Y-%m-%d') as sstart, 
	        date_format(s.send, '%Y-%m-%d') as send,
	        (select count(*) from apply where sno = s.sno) as applycnt		
 		from subject s
 		left join user u on s.uno = u.uno
 		where s.sno not in(select sno from apply where uno = #{uno})
 		
 		<if test="kind == 'usable'">
 			and date_format(s.astart, '%Y%m%d') &lt;= date_format(now(), '%Y%m%d')
 			and date_format(s.aend, '%Y%m%d') &gt;= date_format(now(), '%Y%m%d')
 		</if>
 		<if test="kind == 'closed'">
 			and date_format(s.aend, '%Y%m%d') &lt; date_format(now(), '%Y%m%d')
 		</if>
 		<if test="kind == 'upcoming'">
 			and date_format(s.astart, '%Y%m%d') &gt; date_format(now(), '%Y%m%d')
 		</if>
 		group by s.sno
 		order by s.sno desc
 		limit #{start}, #{perPage}
	</select>
	
	<select id="total" parameterType="map" resultType="int">
		select count(*) from subject s
		where s.sno not in
			(select sno from apply where uno = #{uno})
		<if test="kind == 'usable'">
 			and date_format(s.astart, '%Y%m%d') &lt;= date_format(now(), '%Y%m%d')
 			and date_format(s.aend, '%Y%m%d') &gt;= date_format(now(), '%Y%m%d')
 		</if>
 		<if test="kind == 'closed'">
 			and date_format(s.aend, '%Y%m%d') &lt; date_format(now(), '%Y%m%d')
 		</if>
 		<if test="kind == 'upcoming'">
 			and date_format(s.astart, '%Y%m%d') &gt; date_format(now(), '%Y%m%d')
 		</if>
	</select>
	
	<!-- 내가 신청한 과목 조회 -->
	<select id="myapplylist" parameterType="int" resultType="com.elms.vo.SubjectVO">
		select s.sno, s.sname, s.uno,
		u.name as uname, 
		date_format(s.astart, '%Y-%m-%d') as astart, 
        date_format(s.aend, '%Y-%m-%d') as aend, 
        date_format(s.sstart, '%Y-%m-%d') as sstart, 
        date_format(s.send, '%Y-%m-%d') as send
        from subject s
        left join user u on s.uno = u.uno
		join apply a on s.sno = a.sno
		where a.uno = #{uno}
	</select>
	
	<!-- 전체 수강 신청한 학생 수 조회 -->
	<select id="applyselect" parameterType="java.lang.Integer" resultType="int">
		select count(uno) from apply where uno = #{uno} and sno = #{sno}
	</select>
	
	<!-- 내가 수강 신청한 과목 수 조회 -->
	<select id="myapplyselect" parameterType="java.lang.Integer" resultType="int">
		select count(uno) from apply where uno = #{uno}
	</select>
	
	<!-- 내가 수강 신청한 과목 조회 -->
	<select id="myapplysubject" parameterType="java.lang.Integer" resultType="com.elms.vo.ApplyVO">
		select * from apply where uno = #{uno}
	</select>
	
	<!-- 수강 신청 처리 -->
	<insert id="subjectapply" parameterType="map" useGeneratedKeys="true" keyProperty="ano">
		insert into apply(uno, sno) values(#{uno}, #{sno})
	</insert>
	
	<!-- 수강 신청 취소 처리 -->
	<delete id="applydelete" parameterType="map">
		delete from apply where uno = #{uno} and sno = #{sno}
	</delete>
</mapper>