drop database elmsdb;
create database elmsdb;
use elmsdb;

drop table user;
create table user (
    uno    int primary key auto_increment comment '사용자 번호',
    uid    varchar(100) not null unique comment '이메일',
    pw 	   varchar(255) not null comment '비밀번호',
    num    varchar(255) not null unique comment '학번/사번',
    name   varchar(255) not null comment '이름',
    major  varchar(255) not null comment '학과',
    hp 	   varchar(13) not null comment '핸드폰번호',
    jdate  datetime default now() comment '가입일',
    status char(2) default '01' comment '현재상태',
    appr   char(2) default 'N' comment '승인여부',
    utype  char(2) comment '구분'
) comment '회원정보';

drop table subject;
create table subject (
    sno    int primary key auto_increment comment '과목번호',
    sname  varchar(255) not null comment '과목명',
    astart datetime not null comment '수강신청시작일',
    aend   datetime not null comment '수강신청종료일',
    sstart date not null comment '강의시작일',
    send   date not null comment '강의종료일',
    cnt    int not null comment '수강가능인원',
    uno    int not null comment '사용자번호',
    foreign key (uno) references user (uno)
) comment '과목';

drop table apply;
create table apply (
    ano  int primary key auto_increment comment '수강신청번호',
    uno  int not null comment '사용자번호',
    sno  int not null comment '과목번호',
    foreign key (uno) references user (uno),
    foreign key (sno) references subject (sno)
) comment '수강신청';

drop table task;
create table task (
    tno     int primary key auto_increment comment '과제번호',
    sno     int not null comment '과목번호',
    title   varchar(255) not null comment '과제제목',
    content text not null comment '과제내용',
    edate   datetime not null comment '제출마감일',
    stype   char(2) not null comment '채점방식',
    ttype   char(2) not null comment '과제구분',
    pname   varchar(200) comment '물리파일',
    fname   varchar(200) comment '논리파일',
    wdate   datetime default now() comment '과제등록일',
    foreign key (sno) references subject (sno)
) comment '과제';

drop table submission;
create table submission (
    smno 	 int primary key auto_increment comment '수강과제번호',
    title 	 varchar(200) not null comment '수강과제제목',
    pname 	 varchar(200) comment '과제첨부 물리파일',
    fname 	 varchar(200) comment '과제첨부 논리파일',
    content  text not null comment '수강과제내용',
    smdate   datetime default now() comment '제출일',
    scheck   char(2) default 'N' comment '채점여부',
    score 	 varchar(10) not null comment '최종점수',
    feedback text comment '피드백내용',
    fpname 	 varchar(200) comment '피드백 물리파일',
    ffname 	 varchar(200) comment '피드백 논리파일',
    uno 	 int not null comment '사용자번호',
    tno 	 int not null comment '과제번호',
    foreign key (uno) references user (uno),
    foreign key (tno) references task (tno)
) comment '수강과제';

drop table notice;
create table notice (
    nno 	int primary key auto_increment comment '공지번호',
    title 	varchar(255) not null comment '제목',
    content text not null comment '내용',
    wdate   datetime default now() comment '작성일',
    pname   varchar(200) comment '물리파일',
    fname   varchar(200) comment '논리파일'
) comment '공지사항';

