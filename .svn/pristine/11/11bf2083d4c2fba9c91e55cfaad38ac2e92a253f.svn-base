<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ include file="../../include/teacher/head.jsp" %>
    <div class="main-container">
      <aside>
        <div class="side-menu-top">
         	<a href="../notice/list.do" class="menu-item">공지사항</a>
            <a href="../subject/list.do" class="menu-item">과목 관리</a>
            <a href="../task/list.do" class="menu-item active">과제 게시판</a>
        </div>
<%@ include file="../../include/teacher/side.jsp" %>           
      </aside>

		<main>
			<!-- 1. 페이지 제목 -->
			<div
				class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-2 border-dark">
				<h2 class="m-0 fw-bold text-dark">과제 게시판</h2>
				<button class="btn-batch-approve" onclick="location.href='write.do'">
					<i class="fa-solid fa-plus me-1"></i> 과제 등록
				</button>
			</div>
			<div class="divider"></div>

			<!-- 2. 서브 헤더 (과목명 + 등록 버튼) -->
			<div class="d-flex justify-content-between align-items-center">
				<h4 class="sub-title">개인 웹사이트 테마 선정 및 기획안</h4>

			</div>
			<br>

			<!-- 3. 테이블 영역 -->
			<div class="table-responsive">
				<table class="table custom-table">
					<colgroup>
						<col style="width: 10%;">
						<!-- 구분 -->
						<col style="width: 35%;">
						<!-- 과제명 -->
						<col style="width: 15%;">
						<!-- 제출 현황 -->
						<col style="width: 15%;">
						<!-- 마감일 -->
						<col style="width: 10%;">
						<!-- 채점 -->
						<col style="width: 15%;">
						<!-- 학생 및 채점현황 -->
					</colgroup>
					<thead>
						<c:forEach var="list" items="${ list }">
							<tr>
								<td><span class="badge-pill bg-orange">${ list.ttype }</span></td>
								<td><a href="view.jsp" class="task-link">${ list.title }</a></td>
								<td>30 / 45</td>
								<td>${ list.edate }</td>
								<td>15 / 45</td>
								<td><button class="btn-batch-approve" onclick="location.href='slist.jsp'">보기</button></td>
							</tr>
						</c:forEach>
					</tbody>
				</table>
			</div>

			<!-- 4. 페이지네이션 -->
		<div class="pagination gap-2" style="text-align: center;">
			<c:if test="${ startbk != 1 }">
				<a href="list.do?page=${ startbk - 2 }" class="page-num">◀</a>
			</c:if> 
			<c:forEach var="page" begin="${startbk}" end="${endbk}">
				<c:if test="${ page == pageno }">
					<a href="list.do?page=${ page }" class="page-num active">${ page }</a>
				</c:if>
				<c:if test="${ page != pageno }">
					<a href="list.do?page=${ page }" class="page-num">${ page }</a>
				</c:if>				
			</c:forEach> 
			<c:if test="${ endbk < maxpage }">
				<a href="list.do?page=${ endbk + 1 }" class="page-num">▶</a>
			</c:if>
		</div>

		</main>
	</div>

</body>
</html>