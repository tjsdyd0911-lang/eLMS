insert into submission (title, pname, fname, content, smdate, scheck, score, feedback, fpname, ffname, uno, tno) values
('객체지향 과제 제출합니다_김철수', 'java_kim.pdf', 'oop_summary.pdf', '클래스와 상속 위주로 정리했습니다.', now(), 'Y', '95', '개념 정리가 매우 명확합니다.', null, null, 12, 1),
('자바 과제 제출_이영희', 'java_lee.pdf', 'homework_1.pdf', '다형성 부분이 조금 어렵습니다.', now(), 'Y', '70', '다형성 예제 코드를 보강할 필요가 있습니다.', 'fb_01.pdf', '보강자료.pdf', 13, 1),
('AI 윤리 교육 이수증 제출', 'cert_park.jpg', 'ai_cert.jpg', '강의 시청 완료 후 이수증 캡처하여 올립니다.', now(), 'Y', 'PASS', '이수 확인되었습니다.', null, null, 14, 2),
('윤리 교육 인증샷', 'pic_choi.jpg', 'img_1234.jpg', '수료 화면입니다.', now(), 'Y', 'FAIL', '캡처 화질이 낮아 이름 식별이 불가능합니다. 재제출 바랍니다.', null, null, 15, 2),
('정규화 실습 리포트', 'db_norm_jung.docx', 'report_v1.docx', '3NF까지 변환 과정을 상세히 기술했습니다.', now(), 'Y', '88.5', 'BCNF 고려가 조금 아쉽지만 전반적으로 훌륭합니다.', null, null, 16, 3),
('데이터베이스 과제 제출', 'db_final.docx', 'db_hw.docx', '과제 제출합니다. 확인 부탁드립니다.', now(), 'N', '0', null, null, null, 17, 3),
('현대미술관 관람 인증', 'art_ticket.jpg', 'ticket_auth.jpg', '주말에 다녀왔습니다. 티켓 첨부합니다.', now(), 'Y', 'PASS', '관람 인증 완료. 리포트도 기대하겠습니다.', null, null, 18, 4),
('미술관 다녀왔습니다', 'museum_pic.png', 'photo_v2.png', '인증 사진입니다.', now(), 'N', '0', null, null, null, 19, 4),
('보안 방화벽 정책 보고서_최종', 'sec_firewall.hwp', 'policy_final.hwp', '팀원들과 협의하여 도출된 최종 정책서입니다.', now(), 'Y', '100', '완벽한 분석입니다. 실제 실무에 적용해도 손색없습니다.', null, null, 20, 5),
('방화벽 과제', 'temp.txt', 'memo.txt', '시간이 부족하여 개요만 작성했습니다.', now(), 'Y', '0', '내용이 없어 채점이 불가능합니다. 0점 처리합니다.', null, null, 21, 5);

insert into notice (title, content, wdate, pname, fname) values
('2024학년도 1학기 개강 및 강의실 안내', '2024학년도 1학기 개강을 환영합니다. 본인의 강의실 정보를 반드시 확인하시기 바랍니다.', '2024-02-28 10:00:00', NULL, NULL),
('수강신청 정정 기간 안내', '수강신청 정정 기간은 3월 6일부터 3월 8일 18:00까지입니다.', '2024-03-04 09:00:00', 'n_file_01.pdf', '수강정정매뉴얼.pdf'),
('교내 사물함 배정 신청', '각 단과대별 사물함 신청을 받습니다. 선착순 마감이므로 서둘러 주시기 바랍니다.', '2024-03-05 14:00:00', NULL, NULL),
('신입생 학생증 발급 안내', '신입생 학생증 발급은 학생회관 2층에서 진행됩니다. 신분증을 지참하세요.', '2024-03-10 11:30:00', 'n_file_02.jpg', '학생증사진규격.jpg'),
('교내 무선 인터넷(Wi-Fi) 점검 안내', '네트워크 안정화를 위해 3월 15일 새벽 2시부터 4시까지 Wi-Fi 서비스가 중단됩니다.', '2024-03-13 16:00:00', NULL, NULL),
('2024년도 1학기 국가장학금 2차 신청', '국가장학금 2차 신청 기간입니다. 기간 내 미신청 시 구제가 불가능합니다.', '2024-03-20 09:00:00', 'n_file_03.pdf', '장학금신청가이드.pdf'),
('중간고사 기간 도서관 연장 운영', '중간고사 기간 동안 중앙도서관 열람실을 24시간 개방합니다.', '2024-04-01 10:00:00', NULL, NULL),
('학습관리시스템(LMS) 서버 점검 안내', '안정적인 서비스를 위해 정기 서버 점검을 실시합니다. 이용에 불편을 드려 죄송합니다.', '2024-04-05 18:00:00', NULL, NULL),
('2024학년도 1학기 중간고사 일정 안내', '중간고사 일정은 4월 22일부터 4월 26일까지입니다. 과목별 세부 일정은 담당 교수님께 확인하세요.', '2024-04-08 11:00:00', 'n_file_04.hwp', '중간고사시간표.hwp'),
('교내 셔틀버스 운행 시간 변경', '5월 1일부터 셔틀버스 운행 간격이 조정됩니다. 첨부된 시간표를 참고하세요.', '2024-04-25 15:00:00', 'n_file_05.png', '셔틀버스시간표.png'),
('개교기념일 휴강 안내', '5월 15일은 개교기념일로 모든 수업이 휴강합니다.', '2024-05-01 09:00:00', NULL, NULL),
('봄 대동제(축제) 안전 수칙 안내', '즐거운 축제를 위해 안전 수칙을 준수해 주시기 바랍니다. 주점 운영 시간은 23시까지입니다.', '2024-05-10 13:00:00', 'n_file_06.pdf', '축제안전가이드.pdf'),
('졸업예정자 졸업논문 제출 공지', '이번 학기 졸업 예정자는 5월 31일까지 학과 사무실로 논문을 제출해야 합니다.', '2024-05-15 10:00:00', 'n_file_07.docx', '논문양식.docx'),
('하계 계절학기 수요조사', '여름방학 계절학기 개설 희망 과목 수요조사를 실시합니다.', '2024-05-20 11:00:00', NULL, NULL),
('2024학년도 1학기 기말고사 안내', '기말고사는 6월 17일부터 6월 21일까지 진행됩니다. 부정행위 적발 시 0점 처리됩니다.', '2024-06-01 09:00:00', NULL, NULL),
('강의평가 실시 안내', '이번 학기 수강 과목에 대한 강의평가를 실시합니다. 강의평가를 완료해야 성적 조회가 가능합니다.', '2024-06-05 10:00:00', NULL, NULL),
('하계 방학 중 기숙사 입사 신청', '방학 중 기숙사 잔류를 희망하는 학생은 기간 내 신청 바랍니다.', '2024-06-10 14:00:00', 'n_file_08.zip', '기숙사신청서류.zip'),
('1학기 성적 열람 및 이의신청 기간', '성적 열람 및 정정 기간은 6월 24일부터 6월 26일까지입니다.', '2024-06-18 09:00:00', NULL, NULL),
('교내 편의시설 하계 단축 운영 안내', '방학 기간 동안 학생식당 및 매점 운영 시간이 단축됩니다.', '2024-06-22 10:00:00', NULL, NULL),
('2024학년도 2학기 복학 신청 안내', '휴학생 중 2학기 복학 예정자는 7월 15일부터 복학 신청을 하시기 바랍니다.', '2024-06-25 11:00:00', 'n_file_09.pdf', '복학신청안내.pdf');