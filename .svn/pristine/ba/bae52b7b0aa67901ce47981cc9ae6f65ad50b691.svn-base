package com.elms.service;

import org.apache.ibatis.session.SqlSession;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.bind.annotation.RequestMapping;

import com.elms.vo.UserVO;

@Service
public class TeacherService {

	@Autowired
	private SqlSession session;
	
	private static final String namespace = "elms.teacher";
	
	public boolean PwMatch(String id, String pw) {
		UserVO vo = new UserVO();
		vo.setUid(id);
		vo.setPw(pw);
		int match = session.selectOne(namespace + ".match", vo);
		if( match != 0) {
			return true;
		}
		return false;
	}
	
	
	public UserVO UserInfo(UserVO vo) {
		UserVO UserInfo = session.selectOne(namespace + ".info", vo);
		
		return UserInfo;
	}
	
	public void InfoUpdate(String id, String hp, String pw) {
		UserVO vo = new UserVO();
		vo.setUid(id);
		vo.setHp(hp);
		vo.setPw(pw);
		session.update(namespace + ".update", vo);
		
	}
}
