<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>이젠대학교 ELMS</title>
    <!-- 부트스트랩 및 폰트어썸 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
	<!-- 구글 폰트 (Noto Sans KR) -->
	<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">	
	<!-- Font Awesome 아이콘 -->   
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- admin.css 연동 -->
    <link rel="stylesheet" href="<c:url value='/resources/css/admin.css'/>">
    <script src="<c:url value='/resources/js/jquery-3.7.1.min.js'/>"></script>
</head>
<body>
    <header>
        <div class="logo-section">
            <div class="logo-box">EZ</div>
            <div class="university-name">이젠대학교</div>
        </div>
        <div class="search-bar-container">
            <input type="text" class="search-bar" id="totalKey" name="totalKey" placeholder="공지사항 키워드를 입력하세요." value="${key}">
            <a href="javascript:DoSearchNotice();"><i class="fa-solid fa-magnifying-glass search-icon"></i></a>
        </div>
        <div class="user-info ms-auto">
            <span><strong>[ ${ login.name } ]</strong> 님 환영합니다</span>
			<button class="btn-header" onclick="document.location='<c:url value='/login.do'/>';">로그아웃</button>
        </div>
    </header>
	<script>
	
	function DoSearchNotice()
	{
		document.location = "../notice/list.do?kind=1&key=" + $("#totalKey").val();
	}
	
	</script>    
<!-- include 부분 끝 -->    