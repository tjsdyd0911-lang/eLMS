<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- Namespace를 통해 JAVA 클래스와 Annotation클래스와 동기 -->
<mapper namespace="elms.notice">

	<insert id="write" parameterType="com.elms.vo.NoticeVO"
		useGeneratedKeys="true" keyProperty="nno">
		insert into notice (title,content,wdate,pname,fname)
		values
		(#{title},#{content},now(),
		<if test='fname != null and !fname.equals("")'>
			#{pname},#{fname}
		</if>
		<if test='fname == null or fname.equals("")'>
			null, null
		</if>
		)
	</insert>
	
	<select id="view" parameterType="java.lang.String" 
			resultType="com.elms.vo.NoticeVO">
		select 
			nno,title,content,wdate,pname,fname
		from notice where nno = #{ nno }
	</select>
	
	<update id="update" parameterType="com.elms.vo.NoticeVO">
		update notice set title= #{title}, content = #{content}
		<if test='fname != null and !fname.equals("")'>
		,pname = #{pname},
		fname = #{fname}
		</if>
		where nno = #{ nno }
	</update>
	
	<delete id="delete" parameterType="java.lang.String">
		delete from notice where nno = #{nno}
	</delete>
		
	<select id="total" parameterType="com.elms.vo.SearchVO" resultType="java.lang.Integer">
		select count(*) as total
		from notice
		<if test='kind == "1" and !key.equals("")'>
			where title like '%${ key }%'
		</if>
		<if test='kind == "2" and !key.equals("")'>
			where title like '%${ key }%' or content like '%${ key }%'
		</if>		
	</select>	
	
	<select id="list" parameterType="com.elms.vo.SearchVO"
		resultType="com.elms.vo.NoticeVO">
		select nno,title,date(wdate) as wdate
		from notice 
		<if test='kind == "1" and !key.equals("")'>
			where title like '%${ key }%'
		</if>
		<if test='kind == "2" and !key.equals("")'>
			where title like '%${ key }%' or content like '%${ key }%'
		</if>					
		order by nno desc
		limit #{ offset },10				
	</select>		
</mapper>